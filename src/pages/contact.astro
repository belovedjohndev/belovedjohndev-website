---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import { contactChecklist, contactExpectations, contactLinks } from '../data/siteContent';
---

<MainLayout
  title="Contact | Beloved John Dev"
  description="Start a project conversation about business systems, client portals, estimator tools, or automation."
  canonical="/contact"
  ogImage="/og/contact.svg"
  ogImageAlt="Beloved John Dev contact page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">Contact</p>
      <h1>Start With the Problem You Need the System to Solve</h1>
      <p class="page-hero__lead">
        You do not need a perfect technical brief. A clear description of the broken process,
        spreadsheet pain, or manual handoff is enough to begin.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container contact-grid">
      <article class="panel panel--form">
        <p class="eyebrow eyebrow--small">Project brief</p>
        <h2>Send a Structured Project Inquiry</h2>
        <p class="panel-note">
          This form is designed to make the first message more useful. It helps you describe the workflow problem clearly before we talk about scope.
        </p>

        <form class="project-form" id="project-form">
          <div class="form-grid">
            <label class="form-field">
              <span>Name</span>
              <input type="text" name="name" autocomplete="name" required />
            </label>

            <label class="form-field">
              <span>Company</span>
              <input type="text" name="company" autocomplete="organization" required />
            </label>

            <label class="form-field">
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>

            <label class="form-field">
              <span>Service needed</span>
              <select name="service" required>
                <option value="">Select one</option>
                <option>Custom Business System</option>
                <option>Client Portal or Estimator Tool</option>
                <option>Automation or Integration</option>
                <option>Not sure yet</option>
              </select>
            </label>

            <label class="form-field">
              <span>Budget range</span>
              <select name="budget" required>
                <option value="">Select one</option>
                <option>$1,500 to $3,000</option>
                <option>$3,000 to $6,000</option>
                <option>$6,000 to $12,000</option>
                <option>$12,000+</option>
                <option>Need guidance first</option>
              </select>
            </label>

            <label class="form-field">
              <span>Timeline</span>
              <select name="timeline" required>
                <option value="">Select one</option>
                <option>As soon as possible</option>
                <option>Within 2 to 4 weeks</option>
                <option>Within 1 to 2 months</option>
                <option>Flexible</option>
              </select>
            </label>
          </div>

          <label class="form-field">
            <span>What is breaking in the workflow?</span>
            <textarea
              name="problem"
              rows="5"
              placeholder="Describe the spreadsheet, manual process, disconnected tools, or bottleneck that needs fixing."
              required
            ></textarea>
          </label>

          <label class="form-field">
            <span>What should the system help your team do better?</span>
            <textarea
              name="goal"
              rows="4"
              placeholder="Examples: qualify leads better, reduce admin work, centralize records, improve reporting, speed up quoting."
              required
            ></textarea>
          </label>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Send Brief on WhatsApp</button>
            <button type="button" class="btn btn-dark" id="copy-brief-btn">Copy Brief</button>
            <a href={contactLinks.telegram} class="btn btn-dark" target="_blank" rel="noopener">Open Telegram</a>
          </div>

          <p class="form-status" id="form-status" aria-live="polite"></p>
        </form>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Direct contact</p>
        <h2>Reach Out on the Channel You Prefer</h2>
        <div class="contact-actions">
          <Button href={contactLinks.whatsapp} variant="dark">Start on WhatsApp</Button>
          <Button href={contactLinks.telegram} variant="dark">Message on Telegram</Button>
        </div>
        <p class="panel-note">
          I typically reply within 24 hours with next steps, fit feedback, or follow-up questions.
        </p>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Helpful details</p>
        <h2>What to Include in Your First Message</h2>
        <ul class="check-list">
          {contactChecklist.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container split-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">What happens next</p>
        <h2>What You Can Expect After Contacting Me</h2>
        <ul class="check-list">
          {contactExpectations.map((item) => <li>{item}</li>)}
        </ul>
        <p class="panel-note">
          If pricing is a concern, I can usually tell you early whether the project fits the service ranges shown on the services page or needs a smaller first phase.
        </p>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Focused offer</p>
        <h2>Want a Faster Starting Point?</h2>
        <p>
          The home service estimator offer is already packaged as a focused landing page and demo.
          If your business needs better website lead qualification, that is the fastest page to review.
        </p>
        <div class="contact-actions">
          <Button href="/home-service-estimator" variant="primary">View Estimator Offer</Button>
          <Button href="/case-studies" variant="dark">See More Case Studies</Button>
        </div>
      </article>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero {
    padding: 7rem 0 4rem;
    color: var(--color-white);
    background: linear-gradient(rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.88)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero__content {
    max-width: 820px;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .eyebrow--small {
    color: var(--color-primary);
  }

  .page-hero h1 {
    color: var(--color-white);
  }

  .page-hero__lead,
  .panel p,
  .panel-note {
    line-height: 1.75;
  }

  .page-hero__lead {
    color: rgba(255, 255, 255, 0.92);
  }

  .contact-grid,
  .split-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .panel--form {
    grid-column: 1 / -1;
  }

  .section-light {
    background-color: var(--color-white);
  }

  .contact-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
    line-height: 1.7;
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .project-form {
    margin-top: var(--space-md);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: var(--space-md);
  }

  .form-field span {
    font-weight: 600;
    color: var(--color-dark);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    padding: 0.9rem 1rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(38, 70, 83, 0.14);
    background-color: var(--color-white);
    color: var(--color-text);
    font: inherit;
    transition: var(--transition-fast);
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(42, 157, 143, 0.12);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: 0.875rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 50px;
    transition: var(--transition);
    cursor: pointer;
    border: 2px solid transparent;
    font-family: inherit;
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--color-dark);
  }

  .btn-primary:hover {
    border-color: var(--color-accent);
    color: var(--color-dark);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(244, 162, 97, 0.4);
  }

  .btn-dark {
    background-color: var(--color-dark);
    color: var(--color-white);
  }

  .btn-dark:hover {
    background-color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    color: var(--color-white);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(42, 157, 143, 0.3);
  }

  .form-actions .btn {
    border-radius: 999px;
  }

  .form-status {
    min-height: 1.5rem;
    margin-top: var(--space-sm);
    color: var(--color-primary-dark);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .contact-grid,
    .split-grid,
    .form-grid {
      grid-template-columns: 1fr;
    }

    .contact-actions,
    .form-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  const projectForm = document.getElementById('project-form');
  const copyBriefBtn = document.getElementById('copy-brief-btn');
  const formStatus = document.getElementById('form-status');
  const whatsappBase = 'https://wa.me/855963885424?text=';

  const buildBrief = (formData) => {
    const entries = {
      name: formData.get('name')?.toString().trim() ?? '',
      company: formData.get('company')?.toString().trim() ?? '',
      email: formData.get('email')?.toString().trim() ?? '',
      service: formData.get('service')?.toString().trim() ?? '',
      budget: formData.get('budget')?.toString().trim() ?? '',
      timeline: formData.get('timeline')?.toString().trim() ?? '',
      problem: formData.get('problem')?.toString().trim() ?? '',
      goal: formData.get('goal')?.toString().trim() ?? '',
    };

    return [
      'Hi, I would like to discuss a project.',
      '',
      `Name: ${entries.name}`,
      `Company: ${entries.company}`,
      `Email: ${entries.email}`,
      `Service needed: ${entries.service}`,
      `Budget range: ${entries.budget}`,
      `Timeline: ${entries.timeline}`,
      '',
      'Workflow problem:',
      entries.problem,
      '',
      'What I want the system to improve:',
      entries.goal,
    ].join('\n');
  };

  if (projectForm && formStatus) {
    projectForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(projectForm);
      const brief = buildBrief(formData);
      window.open(`${whatsappBase}${encodeURIComponent(brief)}`, '_blank', 'noopener');
      formStatus.textContent = 'Opening WhatsApp with your structured project brief.';
    });
  }

  if (copyBriefBtn && projectForm && formStatus) {
    copyBriefBtn.addEventListener('click', async () => {
      const formData = new FormData(projectForm);
      const brief = buildBrief(formData);

      try {
        await navigator.clipboard.writeText(brief);
        formStatus.textContent = 'Project brief copied. You can paste it into Telegram or email.';
      } catch {
        formStatus.textContent = 'Copy failed. Please select a contact option and send the details manually.';
      }
    });
  }
</script>
