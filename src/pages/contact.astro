---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import {
  contactChecklist,
  contactExpectations,
  contactLinks,
  ctaLabels,
  idealClients,
  nextStepTimeline,
  notIdealClients,
} from '../data/siteContent';
---

<MainLayout
  title="Contact | Beloved John Dev"
  description="Start a project conversation about business systems, client portals, estimator tools, or automation work."
  canonical="/contact"
  ogImage="/og/contact.svg"
  ogImageAlt="Beloved John Dev contact page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container hero-grid">
      <div class="page-hero__content">
        <p class="eyebrow">Contact</p>
        <h1>Start with the workflow problem you need solved</h1>
        <p class="page-hero__lead">
          You do not need a polished technical brief. A clear description of the broken process, spreadsheet pain,
          weak inquiry flow, or manual handoff is enough to start a useful project conversation.
        </p>
      </div>

      <aside class="hero-panel">
        <p class="hero-panel__label">Good to know</p>
        <p>I typically reply within 24 hours with fit feedback, follow-up questions, or a recommended next step.</p>
        <p>This is best for operationally serious projects, not brochure-site redesign requests.</p>
      </aside>
    </div>
  </section>

  <section class="section-padding">
    <div class="container contact-grid">
      <article class="panel panel--form">
        <p class="eyebrow eyebrow--small">Project brief</p>
        <h2>Send a structured inquiry</h2>
        <p class="panel-note">
          This form is designed to make the first message more useful. It helps qualify the project around workflow,
          budget direction, and business outcomes before we talk about implementation details.
        </p>

        <form class="project-form" id="project-form">
          <div class="form-grid">
            <label class="form-field">
              <span>Name</span>
              <input type="text" name="name" autocomplete="name" required />
            </label>

            <label class="form-field">
              <span>Company</span>
              <input type="text" name="company" autocomplete="organization" required />
            </label>

            <label class="form-field">
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>

            <label class="form-field">
              <span>Service line</span>
              <select name="service" required>
                <option value="">Select one</option>
                <option>Custom Business System</option>
                <option>Client Portal or Estimator Tool</option>
                <option>Automation or Integration</option>
                <option>Not sure yet</option>
              </select>
            </label>

            <label class="form-field">
              <span>Budget direction</span>
              <select name="budget" required>
                <option value="">Select one</option>
                <option>$1,500 to $3,000</option>
                <option>$3,000 to $6,000</option>
                <option>$6,000 to $12,000</option>
                <option>$12,000+</option>
                <option>Need guidance first</option>
              </select>
            </label>

            <label class="form-field">
              <span>Timeline</span>
              <select name="timeline" required>
                <option value="">Select one</option>
                <option>As soon as practical</option>
                <option>Within 2 to 4 weeks</option>
                <option>Within 1 to 2 months</option>
                <option>Flexible / needs scoping</option>
              </select>
            </label>
          </div>

          <label class="form-field">
            <span>What is breaking in the workflow?</span>
            <textarea
              name="problem"
              rows="5"
              placeholder="Describe the spreadsheet, manual process, disconnected tools, or bottleneck that needs fixing."
              required
            ></textarea>
          </label>

          <label class="form-field">
            <span>What should the system help your team do better?</span>
            <textarea
              name="goal"
              rows="4"
              placeholder="Examples: qualify leads better, reduce admin work, centralize records, improve reporting, speed up quoting."
              required
            ></textarea>
          </label>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">{ctaLabels.workflow} on WhatsApp</button>
            <button type="button" class="btn btn-dark" id="copy-brief-btn">Copy brief</button>
            <a href={contactLinks.telegram} class="btn btn-dark" target="_blank" rel="noopener">Open Telegram</a>
            <a href={contactLinks.mailto} class="btn btn-dark">Email support</a>
          </div>

          <p class="form-status" id="form-status" aria-live="polite"></p>
        </form>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Best fit</p>
        <h2>Clients this is built for</h2>
        <ul class="check-list">
          {idealClients.slice(0, 5).map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="panel panel--muted">
        <p class="eyebrow eyebrow--small">Not a fit</p>
        <h2>Projects I am deliberately not positioning around</h2>
        <ul class="check-list">
          {notIdealClients.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Helpful details</p>
        <h2>What to include in the first message</h2>
        <ul class="check-list">
          {contactChecklist.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container split-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">What happens next</p>
        <h2>After you reach out</h2>
        <div class="timeline-list">
          {nextStepTimeline.map((item) => (
            <article class="timeline-item">
              <p class="timeline-item__step">{item.step}</p>
              <div>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </article>
          ))}
        </div>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Response expectations</p>
        <h2>What the first conversation should give you</h2>
        <ul class="check-list">
          {contactExpectations.map((item) => <li>{item}</li>)}
        </ul>
        <div class="contact-actions">
          <Button href="/services" variant="dark">Review service lines</Button>
          <Button href="/case-studies" variant="primary">{ctaLabels.secondary}</Button>
        </div>
      </article>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero {
    padding: 7rem 0 4rem;
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .hero-grid,
  .contact-grid,
  .split-grid,
  .form-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.72fr);
    align-items: start;
  }

  .page-hero__content {
    max-width: 820px;
  }

  .eyebrow,
  .hero-panel__label,
  .timeline-item__step {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eyebrow,
  .hero-panel__label {
    color: var(--color-accent);
  }

  .eyebrow--small,
  .timeline-item__step {
    color: var(--color-primary);
  }

  .page-hero h1 {
    color: var(--color-white);
  }

  .page-hero__lead,
  .hero-panel p,
  .panel p,
  .panel-note,
  .timeline-item p,
  .check-list li {
    line-height: 1.75;
  }

  .page-hero__lead,
  .hero-panel p {
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-panel,
  .panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .hero-panel {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(18px);
  }

  .contact-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel {
    background-color: var(--color-white);
  }

  .panel--form {
    grid-column: 1 / -1;
  }

  .panel--muted {
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
  }

  .section-light {
    background-color: var(--color-white);
  }

  .contact-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
    color: var(--color-text);
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .project-form {
    margin-top: var(--space-md);
  }

  .form-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: var(--space-md);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: var(--space-md);
  }

  .form-field span {
    font-weight: 600;
    color: var(--color-dark);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    padding: 0.9rem 1rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(38, 70, 83, 0.14);
    background-color: var(--color-white);
    color: var(--color-text);
    font: inherit;
    transition: var(--transition-fast);
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(42, 157, 143, 0.12);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: 0.95rem 1.6rem;
    font-size: 0.96rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: 50px;
    transition: var(--transition);
    cursor: pointer;
    border: 2px solid transparent;
    font-family: inherit;
    box-shadow: var(--shadow-sm);
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-accent), #ffd99f);
    color: var(--color-dark);
  }

  .btn-primary:hover {
    border-color: var(--color-accent);
    color: var(--color-dark);
    transform: translateY(-2px);
    box-shadow: 0 16px 30px rgba(240, 188, 116, 0.3);
  }

  .btn-dark {
    background: linear-gradient(135deg, var(--color-dark), var(--color-dark-soft));
    color: var(--color-white);
  }

  .btn-dark:hover {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-dark));
    border-color: rgba(22, 138, 122, 0.5);
    color: var(--color-white);
    transform: translateY(-2px);
    box-shadow: 0 16px 34px rgba(22, 138, 122, 0.24);
  }

  .form-actions .btn {
    border-radius: 999px;
  }

  .form-status {
    min-height: 1.5rem;
    margin-top: var(--space-sm);
    color: var(--color-primary-dark);
    font-weight: 500;
  }

  .timeline-list {
    display: grid;
    gap: var(--space-md);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm);
    align-items: start;
    padding: 1rem;
    border-radius: var(--border-radius-sm);
    background-color: var(--color-light);
    border: 1px solid rgba(42, 157, 143, 0.12);
  }

  .timeline-item__step {
    margin: 0;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .contact-grid,
    .split-grid,
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .contact-actions,
    .form-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  const projectForm = document.getElementById('project-form');
  const copyBriefBtn = document.getElementById('copy-brief-btn');
  const formStatus = document.getElementById('form-status');
  const whatsappBase = 'https://wa.me/855963885424?text=';

  const buildBrief = (formData: FormData) => {
    const entries = {
      name: formData.get('name')?.toString().trim() ?? '',
      company: formData.get('company')?.toString().trim() ?? '',
      email: formData.get('email')?.toString().trim() ?? '',
      service: formData.get('service')?.toString().trim() ?? '',
      budget: formData.get('budget')?.toString().trim() ?? '',
      timeline: formData.get('timeline')?.toString().trim() ?? '',
      problem: formData.get('problem')?.toString().trim() ?? '',
      goal: formData.get('goal')?.toString().trim() ?? '',
    };

    return [
      'Hi, I would like to discuss a project.',
      '',
      `Name: ${entries.name}`,
      `Company: ${entries.company}`,
      `Email: ${entries.email}`,
      `Service line: ${entries.service}`,
      `Budget direction: ${entries.budget}`,
      `Timeline: ${entries.timeline}`,
      '',
      'Workflow problem:',
      entries.problem,
      '',
      'What I want the system to improve:',
      entries.goal,
    ].join('\n');
  };

  if (projectForm instanceof HTMLFormElement && formStatus) {
    projectForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(projectForm);
      const brief = buildBrief(formData);
      window.open(`${whatsappBase}${encodeURIComponent(brief)}`, '_blank', 'noopener');
      formStatus.textContent = 'Opening WhatsApp with your structured project brief.';
    });
  }

  if (copyBriefBtn && projectForm instanceof HTMLFormElement && formStatus) {
    copyBriefBtn.addEventListener('click', async () => {
      const formData = new FormData(projectForm);
      const brief = buildBrief(formData);

      try {
        await navigator.clipboard.writeText(brief);
        formStatus.textContent = 'Project brief copied. You can paste it into Telegram or email.';
      } catch {
        formStatus.textContent = 'Copy failed. Please select a contact option and send the details manually.';
      }
    });
  }
</script>
