---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/ui/Button.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { contactLinks, contactPageContent, ctaLabels, primaryCtaHref } from '../data/siteContent';

const { hero, bestFit, checklist, inquiryForm, nextSteps, alternateContact } = contactPageContent;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://belovedjohndev.com';
const contactFormAction = `https://formsubmit.co/${contactLinks.email}`;
const contactFormSuccessUrl = `${siteUrl}/contact?inquiry=sent#project-inquiry`;
---

<MainLayout
  title="Contact | Beloved John Dev"
  description="Qualified consulting intake for custom business systems, client portals, estimator tools, and workflow automation."
  canonical="/contact"
  ogImage="/og/contact.svg"
  ogImageAlt="Beloved John Dev consulting intake page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero page-hero--contact">
    <div class="container hero-grid">
      <div class="page-hero__content">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p class="page-hero__lead">{hero.lead}</p>
        <p class="page-hero__support">{hero.support}</p>

        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          <a href="#alternate-contact" class="btn-fallback btn-fallback--hero">Alternate contact methods</a>
        </div>
      </div>

      <aside class="surface-card hero-panel">
        <p class="eyebrow">Response</p>
        <h2>{hero.responseTitle}</h2>
        <p class="muted">{hero.responseBody}</p>
        <ul class="bullet-list">
          {hero.responsePoints.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">{bestFit.eyebrow}</p>
        <h2>{bestFit.title}</h2>
        <p>{bestFit.intro}</p>
      </div>

      <div class="project-types-grid">
        {bestFit.projectTypes.map((projectType) => (
          <article class="surface-card project-type-card">
            <p class="project-type-card__index">Best fit</p>
            <h3>{projectType.title}</h3>
            <p>{projectType.summary}</p>
          </article>
        ))}
      </div>

      <article class="surface-card fit-signals-card">
        <div>
          <p class="eyebrow">Fit signals</p>
          <h3>{bestFit.supportTitle}</h3>
        </div>

        <ul class="bullet-list">
          {bestFit.supportItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding section-tint">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">{checklist.eyebrow}</p>
        <h2>{checklist.title}</h2>
        <p>{checklist.intro}</p>
      </div>

      <div class="checklist-grid">
        {checklist.items.map((item, index) => (
          <article class="simple-card checklist-card">
            <p class="checklist-card__number">{String(index + 1).padStart(2, '0')}</p>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding" id="project-inquiry">
    <div class="container">
      <article class="surface-card inquiry-card">
        <div class="inquiry-card__header">
          <p class="eyebrow">{inquiryForm.eyebrow}</p>
          <h2>{inquiryForm.title}</h2>
          <p class="muted">{inquiryForm.intro}</p>
          <p class="delivery-note" id="delivery-note">{inquiryForm.deliveryNote}</p>
        </div>

        <div class="submission-feedback" id="submission-feedback" hidden>
          <p class="eyebrow">Inquiry submitted</p>
          <h3 id="submission-feedback-title">Thanks. The project inquiry was received.</h3>
          <p id="submission-feedback-message">
            Expect fit feedback, follow-up questions, or a recommended next step within about 24 hours.
          </p>
        </div>

        <form
          class="project-form"
          id="project-inquiry-form"
          action={contactFormAction}
          method="post"
          aria-describedby="delivery-note form-status"
        >
          <input type="hidden" name="_subject" value="New consulting inquiry from Beloved John Dev" />
          <input type="hidden" name="_next" value={contactFormSuccessUrl} />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="true" />

          <div class="honeypot-field" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="_honey" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-grid">
            <label class="form-field">
              <span>Name</span>
              <input type="text" id="name" name="name" autocomplete="name" required />
            </label>

            <label class="form-field">
              <span>Email</span>
              <input type="email" id="email" name="email" autocomplete="email" required />
            </label>

            <label class="form-field">
              <span>Company</span>
              <input type="text" id="company" name="company" autocomplete="organization" required />
            </label>

            <label class="form-field">
              <span>Industry</span>
              <input
                type="text"
                id="industry"
                name="industry"
                autocomplete="organization-title"
                required
              />
            </label>

            <label class="form-field">
              <span>Project type</span>
              <select id="projectType" name="projectType" required>
                <option value="">Select one</option>
                {inquiryForm.projectTypeOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Timeline</span>
              <select id="timeline" name="timeline" required>
                <option value="">Select one</option>
                {inquiryForm.timelineOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Budget range</span>
              <select id="budgetRange" name="budgetRange" required>
                <option value="">Select one</option>
                {inquiryForm.budgetRangeOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>

            <label class="form-field form-field--full">
              <span>Current workflow problem</span>
              <textarea
                id="currentWorkflowProblem"
                name="currentWorkflowProblem"
                rows="5"
                placeholder="Describe the process, handoff, delay, or admin bottleneck that is creating friction."
                required
              ></textarea>
            </label>

            <label class="form-field form-field--full">
              <span>Existing tools</span>
              <textarea
                id="existingTools"
                name="existingTools"
                rows="4"
                placeholder="List the tools, spreadsheets, forms, inboxes, or manual workarounds involved today."
                required
              ></textarea>
            </label>

            <label class="form-field form-field--full">
              <span>Target outcome</span>
              <textarea
                id="targetOutcome"
                name="targetOutcome"
                rows="4"
                placeholder="Explain what should work more clearly after the first phase is delivered."
                required
              ></textarea>
            </label>
          </div>

          <div class="form-actions">
            <Button type="submit" variant="primary">Submit Project Inquiry</Button>
          </div>

          <p class="form-status" id="form-status" aria-live="polite">
            If the form service does not complete the submission, use one of the alternate contact methods below.
          </p>

          <noscript>
            <p class="form-noscript">
              JavaScript is not required for form submission. If needed, you can still contact me directly at
              <a href={contactLinks.mailto}>{contactLinks.email}</a>.
            </p>
          </noscript>
        </form>
      </article>
    </div>
  </section>

  <section class="section-padding section-tint">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">{nextSteps.eyebrow}</p>
        <h2>{nextSteps.title}</h2>
        <p>{nextSteps.intro}</p>
      </div>

      <div class="next-steps-grid">
        {nextSteps.items.map((item, index) => (
          <article class="simple-card next-step-card">
            <p class="next-step-card__number">0{index + 1}</p>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding" id="alternate-contact">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">{alternateContact.eyebrow}</p>
        <h2>{alternateContact.title}</h2>
        <p>{alternateContact.intro}</p>
      </div>

      <div class="alternate-contact-grid">
        {alternateContact.methods.map((method) => (
          <article class="surface-card contact-method-card">
            <p class="eyebrow">{method.label}</p>
            <h3>{method.value}</h3>
            <p>{method.description}</p>
            <a href={method.href} target={method.external ? '_blank' : undefined} rel={method.external ? 'noopener' : undefined}>
              Open {method.label}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .hero-grid,
  .project-types-grid,
  .checklist-grid,
  .form-grid,
  .next-steps-grid,
  .alternate-contact-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    align-items: start;
  }

  .page-hero__support {
    max-width: 760px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.8;
  }

  .hero-panel h2 {
    font-size: 1.45rem;
  }

  .hero-panel .bullet-list {
    margin-top: 1rem;
  }

  .btn-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.15rem;
    padding: 0.95rem 1.35rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-white);
    font-weight: 800;
    transition: var(--transition);
  }

  .btn-fallback:hover {
    color: var(--color-white);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.14);
  }

  .project-types-grid,
  .checklist-grid,
  .next-steps-grid,
  .alternate-contact-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .project-type-card,
  .checklist-card,
  .next-step-card,
  .contact-method-card {
    height: 100%;
  }

  .project-type-card__index,
  .checklist-card__number,
  .next-step-card__number {
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-strong);
  }

  .fit-signals-card {
    display: grid;
    grid-template-columns: minmax(220px, 0.42fr) minmax(0, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-lg);
    align-items: start;
  }

  .section-tint {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.72));
  }

  .inquiry-card__header {
    max-width: 760px;
    margin-bottom: var(--space-lg);
  }

  .delivery-note {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
    border-radius: var(--border-radius-sm);
    background: rgba(14, 91, 98, 0.08);
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .submission-feedback {
    margin-bottom: var(--space-lg);
    padding: 1.15rem 1.2rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(14, 91, 98, 0.18);
    background: rgba(14, 91, 98, 0.08);
  }

  .submission-feedback h3 {
    margin-bottom: 0.5rem;
  }

  .project-form {
    display: grid;
    gap: var(--space-lg);
    margin-top: 1.5rem;
  }

  .honeypot-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md) var(--space-lg);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  .form-field span {
    font-weight: 800;
    color: var(--color-dark);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-surface-strong);
    color: var(--color-text);
    transition: var(--transition-fast);
  }

  .form-field input:hover,
  .form-field select:hover,
  .form-field textarea:hover {
    border-color: rgba(14, 91, 98, 0.24);
  }

  .form-field textarea {
    min-height: 130px;
    resize: vertical;
    line-height: 1.65;
  }

  .form-actions {
    display: flex;
    justify-content: flex-start;
    margin-top: 0.25rem;
  }

  .form-actions :global(.btn) {
    min-width: min(100%, 18rem);
  }

  .form-status,
  .form-noscript {
    margin-top: 1rem;
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .contact-method-card a {
    display: inline-flex;
    margin-top: 0.5rem;
    font-weight: 800;
  }

  .contact-method-card h3,
  .contact-method-card p,
  .form-status,
  .form-noscript {
    overflow-wrap: anywhere;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .project-types-grid,
    .checklist-grid,
    .form-grid,
    .next-steps-grid,
    .alternate-contact-grid,
    .fit-signals-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .form-actions {
      justify-content: stretch;
    }

    .form-actions :global(.btn) {
      width: 100%;
      min-width: 0;
    }
  }
</style>

<script>
  const submissionFeedback = document.getElementById('submission-feedback');
  const submissionFeedbackMessage = document.getElementById('submission-feedback-message');
  const formStatus = document.getElementById('form-status');
  const hasSuccessfulSubmission = new URL(window.location.href).searchParams.get('inquiry') === 'sent';

  if (
    hasSuccessfulSubmission &&
    submissionFeedback instanceof HTMLElement &&
    submissionFeedbackMessage instanceof HTMLElement &&
    formStatus instanceof HTMLElement
  ) {
    submissionFeedback.hidden = false;
    submissionFeedbackMessage.textContent =
      'Thanks. The project inquiry was sent successfully. Expect fit feedback, follow-up questions, or a recommended next step within about 24 hours.';
    formStatus.textContent = '';
  }
</script>
