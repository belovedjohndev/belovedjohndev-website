---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/ui/Button.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { contactLinks, contactPageContent, ctaLabels, primaryCtaHref } from '../data/siteContent';

const { hero, inquiryForm, expectation, fitReassurance, nextSteps, alternateContact } = contactPageContent;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://belovedjohndev.com';
const contactFormAction = `https://formsubmit.co/${contactLinks.email}`;
const contactFormSuccessUrl = `${siteUrl}/contact?inquiry=sent#project-inquiry`;
const alternateContactAriaLabels: Record<string, string> = {
  Email: 'Email Beloved John Dev',
  WhatsApp: 'Open WhatsApp',
  Telegram: 'Open Telegram',
};
---

<MainLayout
  title="Start a Project | Beloved John Dev"
  description="Send project context for a custom business system, client portal, estimator tool, dashboard, or workflow automation project."
  canonical="/contact"
  ogImage="/og/contact.svg"
  ogImageAlt="Beloved John Dev consulting intake page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero page-hero--contact">
    <div class="container hero-grid">
      <div class="page-hero__content">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p class="page-hero__lead">{hero.lead}</p>
        <p class="page-hero__support">{hero.support}</p>

        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          <a href="#alternate-contact" class="btn-fallback btn-fallback--hero">Alternate contact methods</a>
        </div>
      </div>

      <aside class="surface-card hero-panel">
        <p class="eyebrow">Response</p>
        <h2>{hero.responseTitle}</h2>
        <p class="muted">{hero.responseBody}</p>
        <ul class="bullet-list">
          {hero.responsePoints.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section-padding expectation-section" aria-labelledby="expectation-heading">
    <div class="container">
      <article class="surface-card expectation-card">
        <p class="eyebrow">{expectation.eyebrow}</p>
        <h2 id="expectation-heading">{expectation.title}</h2>
        <p>{expectation.copy}</p>
        <p class="expectation-support">{expectation.support}</p>
      </article>
    </div>
  </section>

  <section class="section-padding" id="project-inquiry">
    <div class="container">
      <article class="surface-card inquiry-card">
        <div class="inquiry-card__header">
          <p class="eyebrow">{inquiryForm.eyebrow}</p>
          <h2>{inquiryForm.title}</h2>
          <p class="muted">{inquiryForm.intro}</p>
          <p class="delivery-note" id="delivery-note">{inquiryForm.deliveryNote}</p>
        </div>

        <aside class="fit-reassurance" aria-labelledby="fit-reassurance-heading">
          <p class="eyebrow">{fitReassurance.eyebrow}</p>
          <h3 id="fit-reassurance-heading">{fitReassurance.title}</h3>
          <p>{fitReassurance.copy}</p>
        </aside>

        <div class="submission-feedback" id="submission-feedback" hidden>
          <p class="eyebrow">Inquiry submitted</p>
          <h3 id="submission-feedback-title">Thanks. The project inquiry was received.</h3>
          <p id="submission-feedback-message">
            Expect fit feedback, follow-up questions, or a recommended next step within about 24 hours.
          </p>
        </div>

        <form
          class="project-form"
          id="project-inquiry-form"
          action={contactFormAction}
          method="post"
          aria-describedby="delivery-note form-status"
        >
          <input type="hidden" name="_subject" value="New consulting inquiry from Beloved John Dev" />
          <input type="hidden" name="_next" value={contactFormSuccessUrl} />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="true" />

          <div class="honeypot-field" aria-hidden="true">
            <label for="hiddenWebsite">Website</label>
            <input type="text" id="hiddenWebsite" name="_honey" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-grid">
            <label class="form-field">
              <span>Name</span>
              <input type="text" id="name" name="name" autocomplete="name" required />
            </label>

            <label class="form-field">
              <span>Email</span>
              <input type="email" id="email" name="email" autocomplete="email" required />
            </label>

            <label class="form-field">
              <span>Company</span>
              <input type="text" id="company" name="company" autocomplete="organization" required />
            </label>

            <label class="form-field">
              <span>Website or current system URL</span>
              <span class="form-helper" id="businessWebsite-help">
                Optional. Use this for internal systems, pre-launch products, or agency/client work where there may not be a public site.
              </span>
              <input type="url" id="businessWebsite" name="businessWebsite" autocomplete="url" aria-describedby="businessWebsite-help" />
            </label>

            <label class="form-field">
              <span>Industry</span>
              <input
                type="text"
                id="industry"
                name="industry"
                autocomplete="organization-title"
                required
              />
            </label>

            <label class="form-field">
              <span>Project type</span>
              <select id="projectType" name="projectType" required>
                <option value="">Select one</option>
                {inquiryForm.projectTypeOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Timeline</span>
              <select id="timeline" name="timeline" required>
                <option value="">Select one</option>
                {inquiryForm.timelineOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Budget range</span>
              <select id="budgetRange" name="budgetRange" required>
                <option value="">Select one</option>
                {inquiryForm.budgetRangeOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>

            <label class="form-field form-field--full">
              <span>Current workflow problem</span>
              <span class="form-helper" id="currentWorkflowProblem-help">
                Describe what currently happens, who is involved, and where it breaks down. Rough notes are fine.
              </span>
              <textarea
                id="currentWorkflowProblem"
                name="currentWorkflowProblem"
                rows="5"
                placeholder="Describe what currently happens, who is involved, and where it breaks down. Rough notes are fine."
                aria-describedby="currentWorkflowProblem-help"
                required
              ></textarea>
            </label>

            <label class="form-field form-field--full">
              <span>Current tools/process</span>
              <span class="form-helper" id="existingTools-help">
                List the tools, spreadsheets, forms, inboxes, or manual steps involved today.
              </span>
              <textarea
                id="existingTools"
                name="existingTools"
                rows="4"
                placeholder="List the tools, spreadsheets, forms, inboxes, or manual steps involved today."
                aria-describedby="existingTools-help"
                required
              ></textarea>
            </label>

            <label class="form-field form-field--full">
              <span>What should be better after the first phase?</span>
              <span class="form-helper" id="targetOutcome-help">
                Explain what should be easier, clearer, faster, or more reliable after the first useful phase.
              </span>
              <textarea
                id="targetOutcome"
                name="targetOutcome"
                rows="4"
                placeholder="Example: cleaner intake, faster review, and clearer status for the team."
                aria-describedby="targetOutcome-help"
                required
              ></textarea>
            </label>
          </div>

          <div class="form-actions">
            <Button type="submit" variant="primary">Send Project Context</Button>
          </div>

          <p class="form-status" id="form-status" aria-live="polite">
            Trouble submitting? Use a direct contact option below.
          </p>

          <noscript>
            <p class="form-noscript">
              JavaScript is not required for form submission. If needed, you can still contact me directly at
              <a href={contactLinks.mailto}>{contactLinks.email}</a>.
            </p>
          </noscript>
        </form>

        <section class="next-steps-panel" aria-labelledby="next-steps-heading">
          <p class="eyebrow">{nextSteps.eyebrow}</p>
          <h3 id="next-steps-heading">{nextSteps.title}</h3>
          <p>{nextSteps.intro}</p>
          <ol class="next-steps-list">
            {nextSteps.items.map((item) => <li>{item}</li>)}
          </ol>
        </section>
      </article>
    </div>
  </section>

  <section class="section-padding" id="alternate-contact">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">{alternateContact.eyebrow}</p>
        <h2>{alternateContact.title}</h2>
        <p>{alternateContact.intro}</p>
      </div>

      <div class="alternate-contact-actions" aria-label="Direct contact methods">
        {alternateContact.methods.map((method) => (
          <a
            class="contact-action-link"
            href={method.href}
            target={method.external ? '_blank' : undefined}
            rel={method.external ? 'noopener' : undefined}
            aria-label={alternateContactAriaLabels[method.label] ?? `Open ${method.label}`}
          >
            {method.label === 'Email' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            )}
            {method.label === 'WhatsApp' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
            )}
            {method.label === 'Telegram' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/></svg>
            )}
            {method.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .hero-grid,
  .form-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    align-items: start;
  }

  .page-hero__support {
    max-width: 760px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.8;
  }

  .hero-panel h2 {
    font-size: 1.45rem;
  }

  .hero-panel .bullet-list {
    margin-top: 1rem;
  }

  .btn-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0.6rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-white);
    font-weight: 800;
    white-space: nowrap;
    transition: var(--transition);
  }

  .btn-fallback:hover {
    color: var(--color-white);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.14);
  }

  .expectation-section {
    background: rgba(255, 255, 255, 0.45);
  }

  .expectation-card {
    max-width: 860px;
  }

  .expectation-card p:last-child,
  .fit-reassurance p:last-child,
  .next-steps-panel p {
    margin-bottom: 0;
  }

  .expectation-support {
    color: var(--color-primary-dark);
    font-weight: 800;
  }

  .inquiry-card__header {
    max-width: 760px;
    margin-bottom: var(--space-lg);
  }

  .fit-reassurance,
  .next-steps-panel {
    margin-bottom: var(--space-lg);
    padding: 1.15rem 1.2rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(14, 91, 98, 0.18);
    background: rgba(14, 91, 98, 0.08);
  }

  .fit-reassurance h3,
  .next-steps-panel h3 {
    margin-bottom: 0.6rem;
    font-size: 1.25rem;
  }

  .delivery-note {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
    border-radius: var(--border-radius-sm);
    background: rgba(14, 91, 98, 0.08);
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .submission-feedback {
    margin-bottom: var(--space-lg);
    padding: 1.15rem 1.2rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(14, 91, 98, 0.18);
    background: rgba(14, 91, 98, 0.08);
  }

  .submission-feedback h3 {
    margin-bottom: 0.5rem;
  }

  .project-form {
    display: grid;
    gap: 1.35rem;
    margin-top: 1.5rem;
  }

  .next-steps-panel {
    margin-top: var(--space-lg);
    margin-bottom: 0;
  }

  .next-steps-list {
    display: grid;
    gap: 0.7rem;
    margin-top: 1rem;
    padding-left: 1.25rem;
  }

  .next-steps-list li {
    color: var(--color-text);
    line-height: 1.65;
  }

  .honeypot-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem 1.5rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  .form-field > span:not(.form-helper) {
    font-weight: 800;
    color: var(--color-dark);
  }

  .form-helper {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-surface-strong);
    color: var(--color-text);
    transition: var(--transition-fast);
  }

  .form-field input:hover,
  .form-field select:hover,
  .form-field textarea:hover {
    border-color: rgba(14, 91, 98, 0.24);
  }

  .form-field textarea {
    min-height: 130px;
    resize: vertical;
    line-height: 1.65;
  }

  .form-actions {
    display: flex;
    justify-content: flex-start;
    margin-top: 0.25rem;
  }

  .form-actions :global(.btn) {
    min-width: min(100%, 18rem);
  }

  .form-status,
  .form-noscript {
    margin-top: 1rem;
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .alternate-contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .contact-action-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.6rem;
    min-width: 7.5rem;
    padding: 0.55rem 0.95rem;
    border-radius: 12px;
    border: 1px solid rgba(12, 31, 51, 0.12);
    background: var(--color-surface-strong);
    color: var(--color-dark);
    font-weight: 800;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }

  .contact-action-link:hover {
    color: var(--color-white);
    text-decoration: none;
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .form-status,
  .form-noscript {
    overflow-wrap: anywhere;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .btn-fallback {
      width: 100%;
      white-space: normal;
    }

    .form-actions {
      justify-content: stretch;
    }

    .form-actions :global(.btn) {
      width: 100%;
      min-width: 0;
    }

    .alternate-contact-actions {
      flex-direction: column;
    }

    .contact-action-link {
      width: 100%;
    }
  }
</style>

<script>
  const submissionFeedback = document.getElementById('submission-feedback');
  const submissionFeedbackMessage = document.getElementById('submission-feedback-message');
  const formStatus = document.getElementById('form-status');
  const hasSuccessfulSubmission = new URL(window.location.href).searchParams.get('inquiry') === 'sent';

  if (
    hasSuccessfulSubmission &&
    submissionFeedback instanceof HTMLElement &&
    submissionFeedbackMessage instanceof HTMLElement &&
    formStatus instanceof HTMLElement
  ) {
    submissionFeedback.hidden = false;
    submissionFeedbackMessage.textContent =
      'Thanks. The project inquiry was sent successfully. Expect fit feedback, follow-up questions, or a recommended next step within about 24 hours.';
    formStatus.textContent = '';
  }
</script>
