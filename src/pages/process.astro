---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import FAQ from '../components/sections/FAQ.astro';
import { ctaLabels, engagementModel, nextStepTimeline, processSteps } from '../data/siteContent';
---

<MainLayout
  title="Process | Beloved John Dev"
  description="A practical process for discovery, scoping, development, launch, and post-launch support for business systems work."
  canonical="/process"
  ogImage="/og/process.svg"
  ogImageAlt="Beloved John Dev process share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">Process</p>
      <h1>A practical process for operational software projects</h1>
      <p class="page-hero__lead">
        Serious clients want to know how the work moves before they commit. The process here is structured enough
        to reduce risk and practical enough to stay focused on the workflow that actually needs fixing.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container process-grid">
      {processSteps.map((step) => (
        <article class="process-card">
          <p class="process-number">{step.number}</p>
          <h2>{step.title}</h2>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container split-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">Engagement model</p>
        <h2>How projects are usually structured</h2>
        <div class="engagement-list">
          {engagementModel.map((item) => (
            <article class="engagement-item">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">After inquiry</p>
        <h2>What happens after the first message</h2>
        <div class="timeline-list">
          {nextStepTimeline.map((item) => (
            <article class="timeline-item">
              <p class="timeline-item__step">{item.step}</p>
              <div>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </article>
          ))}
        </div>
      </article>
    </div>
  </section>

  <FAQ />

  <section class="section-padding cta-band">
    <div class="container cta-band__content">
      <p class="eyebrow">Next step</p>
      <h2>Bring the broken workflow. I can help shape the first useful phase.</h2>
      <p>
        You do not need a full requirements document to begin. A clear explanation of the bottleneck,
        the spreadsheet pain, or the weak handoff is enough to make the first conversation useful.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/services" variant="secondary">View service lines</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero,
  .cta-band {
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero {
    padding: 7rem 0 4rem;
  }

  .page-hero__content,
  .cta-band__content {
    max-width: 820px;
  }

  .eyebrow,
  .process-number,
  .timeline-item__step {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .eyebrow {
    color: var(--color-accent);
  }

  .eyebrow--small,
  .process-number,
  .timeline-item__step {
    color: var(--color-primary);
  }

  .page-hero h1,
  .cta-band h2 {
    color: var(--color-white);
  }

  .page-hero__lead,
  .cta-band p,
  .process-card p,
  .engagement-item p,
  .timeline-item p {
    line-height: 1.75;
  }

  .page-hero__lead,
  .cta-band p {
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .process-grid,
  .split-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .process-grid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .split-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .process-card,
  .panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .section-light {
    background-color: var(--color-white);
  }

  .engagement-list,
  .timeline-list {
    display: grid;
    gap: var(--space-md);
  }

  .engagement-item,
  .timeline-item {
    padding: 1rem;
    border-radius: var(--border-radius-sm);
    background-color: var(--color-light);
    border: 1px solid rgba(42, 157, 143, 0.12);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm);
    align-items: start;
  }

  .timeline-item__step {
    margin: 0;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .split-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
