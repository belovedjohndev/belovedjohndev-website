---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import FAQ from '../components/sections/FAQ.astro';
import { processSteps } from '../data/siteContent';
---

<MainLayout
  title="Process | Beloved John Dev"
  description="A practical process for discovery, system design, development, launch, and support."
  canonical="/process"
  ogImage="/og/process.svg"
  ogImageAlt="Beloved John Dev process share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">Process</p>
      <h1>A Practical Delivery Process for Business Software Projects</h1>
      <p class="page-hero__lead">
        Serious clients want to know how the work moves. The process is structured enough
        to reduce risk and simple enough to stay focused on the real workflow problem.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">Start a Project Conversation</Button>
        <Button href="/case-studies" variant="secondary">See the Work</Button>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container process-grid">
      {processSteps.map((step) => (
        <article class="process-card">
          <p class="process-number">{step.number}</p>
          <h2>{step.title}</h2>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container split-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">What clients can expect</p>
        <h2>How I Try to Keep Projects Healthy</h2>
        <ul class="check-list">
          <li>Clear priorities before unnecessary features</li>
          <li>Direct communication with the builder</li>
          <li>Sensible milestones instead of vague long timelines</li>
          <li>Architecture choices driven by maintainability</li>
          <li>Post-launch support when the system enters real use</li>
        </ul>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Why this matters</p>
        <h2>Operational Software Needs a Different Mindset</h2>
        <p>
          When software is tied to quoting, admin work, records, approvals, or client handoff,
          the process has to stay grounded in real usage. The goal is not to impress with complexity.
          It is to make the workflow clearer and more dependable.
        </p>
      </article>
    </div>
  </section>

  <FAQ />

  <section class="section-padding cta-band">
    <div class="container cta-band__content">
      <p class="eyebrow">Next step</p>
      <h2>Bring the Workflow Problem First</h2>
      <p>
        If you can explain where the current process breaks, we can usually figure out whether
        a custom system, a portal, or a focused automation layer makes the most sense.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">Discuss Your Project</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero,
  .cta-band {
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero {
    padding: 7rem 0 4rem;
  }

  .page-hero__content,
  .cta-band__content {
    max-width: 820px;
  }

  .eyebrow,
  .process-number {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .eyebrow {
    color: var(--color-accent);
  }

  .eyebrow--small,
  .process-number {
    color: var(--color-primary);
  }

  .page-hero h1,
  .cta-band h2 {
    color: var(--color-white);
  }

  .page-hero__lead,
  .cta-band p {
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .process-grid,
  .split-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .process-grid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .split-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .process-card,
  .panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .section-light {
    background-color: var(--color-white);
  }

  .process-card p,
  .panel p {
    line-height: 1.75;
    color: var(--color-text);
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
    line-height: 1.7;
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .split-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
