---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import JsonLd from '../../components/JsonLd.astro';
import { caseStudies, ctaLabels, insights, primaryCtaHref, servicePages } from '../../data/siteContent';

export function getStaticPaths() {
  return insights.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://belovedjohndev.com';
const articleUrl = `${siteUrl}/insights/${article.slug}`;
const relatedLinksByInsightSlug: Record<string, { service: string; caseStudy: string }> = {
  'when-spreadsheets-become-the-bottleneck': {
    service: 'custom-business-systems',
    caseStudy: 'church-management-system',
  },
  'why-most-quote-forms-create-bad-leads': {
    service: 'client-portals-estimator-tools',
    caseStudy: 'estimate-engine',
  },
  'internal-tools-vs-forcing-your-workflow-into-saas': {
    service: 'custom-business-systems',
    caseStudy: 'church-management-system',
  },
  'what-to-define-before-building-a-custom-system': {
    service: 'custom-business-systems',
    caseStudy: 'custom-project-management-web-app',
  },
  'custom-business-system-vs-spreadsheet-workflow': {
    service: 'custom-business-systems',
    caseStudy: 'church-management-system',
  },
  'client-portal-vs-basic-contact-form': {
    service: 'client-portals-estimator-tools',
    caseStudy: 'estimate-engine',
  },
  'when-to-build-a-custom-estimator-tool': {
    service: 'client-portals-estimator-tools',
    caseStudy: 'estimate-engine',
  },
  'internal-tool-vs-off-the-shelf-saas': {
    service: 'custom-business-systems',
    caseStudy: 'custom-project-management-web-app',
  },
};
const relatedLinkSlugs = relatedLinksByInsightSlug[article.slug];
const relatedService = servicePages.find((service) => service.slug === relatedLinkSlugs?.service);
const relatedCaseStudy = caseStudies.find((study) => study.slug === relatedLinkSlugs?.caseStudy);
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Insights',
      item: `${siteUrl}/insights`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.title,
      item: articleUrl,
    },
  ],
};
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: article.title,
  description: article.summary,
  url: articleUrl,
  mainEntityOfPage: articleUrl,
  articleSection: article.category,
  author: {
    '@type': 'Person',
    name: 'Beloved John Dev',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Beloved John Dev',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/assets/images/logo-ui.png`,
    },
  },
  inLanguage: 'en',
};
---

<MainLayout
  title={`${article.title} | Insights | Beloved John Dev`}
  description={article.summary}
  canonical={`/insights/${article.slug}`}
  ogImage={`/og/insights/${article.slug}.png`}
  ogImageAlt={`${article.title} insight share image`}
>
  <Navbar slot="navbar" />
  <JsonLd data={breadcrumbSchema} />
  <JsonLd data={articleSchema} />

  <article>
    <section class="page-hero page-hero--insights">
      <div class="container page-hero__content">
        <p class="eyebrow">{article.category}</p>
        <h1>{article.title}</h1>
        <p class="page-hero__lead">{article.summary}</p>
        <p class="page-hero__lead">{article.audience}</p>
        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
        </div>
      </div>
    </section>

    <section class="section-padding takeaway-band">
      <div class="container">
        <div class="surface-card">
          <p class="eyebrow">Key takeaways</p>
          <ul class="takeaway-list">
            {article.takeaways.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section-padding article-band">
      <div class="container article-body">
        <p class="article-intro">{article.intro}</p>

        {article.sections.map((section) => (
          <section class="article-section">
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>
    </section>

    {(relatedService || relatedCaseStudy) && (
      <section class="section-padding related-strip">
        <div class="container related-links-card">
          <p class="eyebrow">Related proof</p>
          <h2>Service and case study context</h2>
          <div class="related-link-list">
            {relatedService && <a href={`/services/${relatedService.slug}`}>Service: {relatedService.title}</a>}
            {relatedCaseStudy && <a href={`/case-studies/${relatedCaseStudy.slug}`}>Case study: {relatedCaseStudy.title}</a>}
          </div>
        </div>
      </section>
    )}

    <section class="section-padding cta-frame">
      <div class="container cta-frame__content">
        <p class="eyebrow">Next step</p>
        <h2>If this sounds familiar, start with the workflow problem.</h2>
        <p>
          Share the current process, where it breaks down, and what the first useful phase should improve.
          The common thread is that the software should remove friction instead of adding more process around it.
        </p>
        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
        </div>
      </div>
    </section>
  </article>

  <Footer slot="footer" />
</MainLayout>

<style>
  .takeaway-band {
    background: rgba(255, 255, 255, 0.45);
  }

  .takeaway-list {
    list-style: none;
    display: grid;
    gap: 0.5rem;
    margin-bottom: 0;
  }

  .takeaway-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .takeaway-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.45;
  }

  .article-band {
    background: var(--color-surface-strong);
  }

  .article-body {
    max-width: 820px;
  }

  .article-intro,
  .article-section p {
    line-height: 1.85;
  }

  .article-intro {
    font-size: 1.05rem;
    margin-bottom: var(--space-xl);
  }

  .article-section + .article-section {
    margin-top: var(--space-xl);
  }

  .related-strip {
    background: rgba(255, 255, 255, 0.45);
  }

  .related-links-card {
    display: grid;
    gap: 1rem;
  }

  .related-links-card h2 {
    margin-bottom: 0;
  }

  .related-link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .related-link-list a {
    display: inline-flex;
    padding: 0.75rem 0.9rem;
    border-radius: var(--border-radius-sm);
    background: rgba(14, 91, 98, 0.08);
    font-weight: 800;
  }
</style>
