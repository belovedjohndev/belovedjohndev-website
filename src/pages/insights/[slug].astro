---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { ctaLabels, insights, primaryCtaHref } from '../../data/siteContent';

export function getStaticPaths() {
  return insights.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<MainLayout
  title={`${article.title} | Guides | Beloved John Dev`}
  description={article.summary}
  canonical={`/insights/${article.slug}`}
  ogImage={`/og/insights/${article.slug}.svg`}
  ogImageAlt={`${article.title} insight share image`}
>
  <Navbar slot="navbar" />

  <article>
    <section class="page-hero page-hero--insights">
      <div class="container page-hero__content">
        <p class="eyebrow">{article.category}</p>
        <h1>{article.title}</h1>
        <p class="page-hero__lead">{article.summary}</p>
        <p class="page-hero__lead"><strong>{article.readingTime}</strong> | {article.audience}</p>
        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
        </div>
      </div>
    </section>

    <section class="section-padding takeaway-band">
      <div class="container">
        <div class="surface-card">
          <p class="eyebrow">Key takeaways</p>
          <div class="chip-row">
            {article.takeaways.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding article-band">
      <div class="container article-body">
        <p class="article-intro">{article.intro}</p>

        {article.sections.map((section) => (
          <section class="article-section">
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>
    </section>

    <section class="section-padding cta-frame">
      <div class="container cta-frame__content">
        <p class="eyebrow">Next step</p>
        <h2>If this article sounds familiar, the workflow probably needs a stronger system.</h2>
        <p>
          The right first phase might be a business system, an estimator tool, or a focused automation layer.
          The common thread is that the software should remove friction instead of adding more process around it.
        </p>
        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
        </div>
      </div>
    </section>
  </article>

  <Footer slot="footer" />
</MainLayout>

<style>
  .takeaway-band {
    background: rgba(255, 255, 255, 0.45);
  }

  .article-band {
    background: var(--color-surface-strong);
  }

  .article-body {
    max-width: 820px;
  }

  .article-intro,
  .article-section p {
    line-height: 1.85;
  }

  .article-intro {
    font-size: 1.05rem;
    margin-bottom: var(--space-xl);
  }

  .article-section + .article-section {
    margin-top: var(--space-xl);
  }
</style>
