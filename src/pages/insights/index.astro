---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { ctaLabels, insights, primaryCtaHref } from '../../data/siteContent';
---

<MainLayout
  title="Insights for Custom Business Systems | Beloved John Dev"
  description="Practical insights for deciding when a workflow needs a custom system, client portal, estimator tool, or automation."
  canonical="/insights"
  ogImage="/og/insights.svg"
  ogImageAlt="Beloved John Dev insights page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero page-hero--insights">
    <div class="container page-hero__content">
      <p class="eyebrow">Insights</p>
      <h1>Insights for deciding what your workflow needs next</h1>
      <p class="page-hero__lead">
        Use these articles to clarify the workflow problem, compare practical options, and decide what a useful first
        phase should improve.
      </p>
      <div class="hero-actions">
        <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container insight-grid">
      {insights.map((article) => (
        <article class="surface-card insight-card">
          <p class="eyebrow">{article.category}</p>
          <h2>{article.title}</h2>
          <p>{article.summary}</p>
          <p class="muted">{article.audience}</p>
          <div class="chip-row">
            {article.takeaways.slice(0, 3).map((takeaway) => (
              <span class="chip">{takeaway}</span>
            ))}
          </div>
          <Button href={`/insights/${article.slug}`} variant="dark">Read Insight</Button>
        </article>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .insight-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .insight-card {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .insight-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
