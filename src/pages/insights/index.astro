---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { ctaLabels, insights } from '../../data/siteContent';
---

<MainLayout
  title="Insights | Beloved John Dev"
  description="Short thinking on business systems, workflow bottlenecks, estimator tools, and custom software buying decisions."
  canonical="/insights"
  ogImage="/og/insights.svg"
  ogImageAlt="Beloved John Dev insights page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">Insights</p>
      <h1>Short writing on workflow friction, custom systems, and better buying decisions</h1>
      <p class="page-hero__lead">
        These articles are here to show how I think before code is written: where the operational friction comes
        from, what software should actually improve, and how to choose the right first move.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container insight-grid">
      {insights.map((article) => (
        <article class="surface-card insight-card">
          <p class="eyebrow">{article.category}</p>
          <h2>{article.title}</h2>
          <p>{article.summary}</p>
          <p class="muted"><strong>{article.readingTime}</strong> | {article.audience}</p>
          <div class="chip-row">
            {article.takeaways.slice(0, 3).map((takeaway) => (
              <span class="chip">{takeaway}</span>
            ))}
          </div>
          <Button href={`/insights/${article.slug}`} variant="dark">Read the Insight</Button>
        </article>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .insight-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .insight-card {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .insight-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
