---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import {
  idealClients,
  notIdealClients,
  serviceOffers,
  supportingCapabilities,
} from '../data/siteContent';
---

<MainLayout
  title="Services | Beloved John Dev"
  description="Custom business systems, client portals, estimator tools, and automation services for companies with manual workflows."
  canonical="/services"
  ogImage="/og/services.svg"
  ogImageAlt="Beloved John Dev services share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">Services</p>
      <h1>What You Can Hire Me to Build</h1>
      <p class="page-hero__lead">
        The offer is intentionally narrow: custom business systems, client-facing tools,
        and automation for companies that have outgrown spreadsheets, manual work, and disconnected software.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">Discuss Your Workflow</Button>
        <Button href="/case-studies" variant="secondary">See Case Studies</Button>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="services-intro">
        <p>
          Each offer is designed to answer a simple hiring question: what kind of business problem am I solving, and what kind of system am I building to solve it?
        </p>
        <p class="services-intro__muted">
          Pricing starts at the ranges below. Final scope depends on workflow complexity, integrations, and how much business logic needs to be built into the system.
        </p>
      </div>
      <div class="services-grid">
        {serviceOffers.map((service) => (
          <article class="service-card">
            <p class="eyebrow eyebrow--small">{service.title}</p>
            <h2>{service.summary}</h2>
            <p class="service-description">{service.description}</p>

            <div class="pricing-panel">
              <p class="pricing-panel__label">Starting at</p>
              <p class="pricing-panel__price">{service.startingPrice}</p>
              <p class="pricing-panel__note">{service.pricingNote}</p>
            </div>

            <div class="service-block">
              <h3>Common examples</h3>
              <ul class="check-list">
                {service.examples.map((item) => <li>{item}</li>)}
              </ul>
            </div>

            <div class="service-block">
              <h3>What this can include</h3>
              <ul class="check-list">
                {service.includes.map((item) => <li>{item}</li>)}
              </ul>
            </div>

            <div class="service-block">
              <h3>Typical outcomes</h3>
              <div class="pill-list" role="list">
                {service.outcomes.map((outcome) => (
                  <span class="pill" role="listitem">{outcome}</span>
                ))}
              </div>
            </div>

            <p class="service-best-fit"><strong>Best fit:</strong> {service.bestFor}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container fit-grid">
      <article class="fit-card">
        <p class="eyebrow eyebrow--small">Best fit</p>
        <h2>Clients I Want This Site to Attract</h2>
        <ul class="check-list">
          {idealClients.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="fit-card fit-card--muted">
        <p class="eyebrow eyebrow--small">Not the focus</p>
        <h2>Work I Am Deliberately De-Emphasizing</h2>
        <ul class="check-list">
          {notIdealClients.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding">
    <div class="container pricing-note-card">
      <p class="eyebrow eyebrow--small">Pricing guidance</p>
      <h2>Why I Show Starting Ranges</h2>
      <p>
        The goal is to help serious clients self-qualify early. These are not fixed packages.
        They are consulting and build engagements shaped around the workflow, the number of users,
        the integrations involved, and the level of internal complexity.
      </p>
      <p>
        If the business problem is real but the right first version is smaller, I would rather scope
        a practical first phase than inflate the build.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container capabilities-card">
      <p class="eyebrow eyebrow--small">Supporting capabilities</p>
      <h2>Additional Technical Strength Around the Core Offers</h2>
      <p class="capabilities-copy">
        These are supporting capabilities that make the main offers more dependable, not separate generic services I am trying to sell on their own.
      </p>
      <div class="pill-list" role="list">
        {supportingCapabilities.map((capability) => (
          <span class="pill pill--dark" role="listitem">{capability}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding cta-band">
    <div class="container cta-band__content">
      <p class="eyebrow">Next step</p>
      <h2>Start With the Workflow Problem, Not the Tech Stack</h2>
      <p>
        If you already know the bottleneck, the spreadsheet pain, or the manual handoff that
        needs fixing, that is enough to start a useful conversation. We can scope the first useful version from there.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">Discuss Your System</Button>
        <Button href="/home-service-estimator" variant="secondary">View Estimator Offer</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero,
  .cta-band {
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero {
    padding: 7rem 0 4rem;
  }

  .page-hero__content,
  .cta-band__content {
    max-width: 820px;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .eyebrow--small {
    color: var(--color-primary);
  }

  .page-hero h1,
  .cta-band h2 {
    color: var(--color-white);
  }

  .page-hero__lead,
  .cta-band p {
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .section-light {
    background-color: var(--color-white);
  }

  .services-grid,
  .fit-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .services-intro {
    max-width: 820px;
    margin-bottom: var(--space-xl);
  }

  .services-intro p,
  .capabilities-copy,
  .pricing-note-card p {
    line-height: 1.75;
    color: var(--color-text);
  }

  .services-intro__muted {
    color: var(--color-text-muted);
  }

  .services-grid {
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }

  .fit-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .service-card,
  .fit-card,
  .capabilities-card,
  .pricing-note-card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .pricing-panel {
    margin-top: var(--space-md);
    padding: var(--space-md);
    border-radius: var(--border-radius-sm);
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
    border: 1px solid rgba(42, 157, 143, 0.16);
  }

  .pricing-panel__label {
    margin-bottom: 0.25rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .pricing-panel__price {
    margin-bottom: 0.35rem;
    font-size: 1.8rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-dark);
  }

  .pricing-panel__note {
    margin-bottom: 0;
    color: var(--color-text);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .fit-card--muted {
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
  }

  .service-card h2,
  .fit-card h2,
  .capabilities-card h2 {
    font-size: 1.55rem;
  }

  .service-description,
  .service-best-fit {
    color: var(--color-text);
    line-height: 1.75;
  }

  .service-block {
    margin-top: var(--space-md);
  }

  .service-block h3 {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
    line-height: 1.7;
    color: var(--color-text);
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background-color: rgba(42, 157, 143, 0.08);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.92rem;
  }

  .pill--dark {
    background-color: var(--color-light);
    color: var(--color-dark);
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .fit-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
