---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BuyerGuide from '../components/sections/BuyerGuide.astro';
import Button from '../components/ui/Button.astro';
import {
  ctaLabels,
  operationalProblemsSolved,
  serviceOffers,
  supportingCapabilities,
  systemsCommonlyBuilt,
} from '../data/siteContent';
---

<MainLayout
  title="Services | Beloved John Dev"
  description="Productized service lines for custom business systems, client portals, estimator tools, and automation work."
  canonical="/services"
  ogImage="/og/services.svg"
  ogImageAlt="Beloved John Dev services share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container hero-grid">
      <div class="page-hero__content">
        <p class="eyebrow">Services</p>
        <h1>Productized service lines for businesses with real workflow friction</h1>
        <p class="page-hero__lead">
          The offer is intentionally narrow: custom business systems, client-facing tools, and automation work
          for teams that need operational clarity more than another generic website project.
        </p>
        <div class="hero-actions">
          <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
          <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
        </div>
      </div>

      <aside class="hero-panel">
        <p class="hero-panel__label">How to use this page</p>
        <p>
          Start with the service line that best matches the bottleneck in your workflow. If more than one feels relevant,
          the right first phase is usually chosen after reviewing the current process and handoffs.
        </p>
      </aside>
    </div>
  </section>

  <section class="section-padding">
    <div class="container services-grid">
      {serviceOffers.map((service) => (
        <article class="service-card" id={service.slug}>
          <div class="service-card__header">
            <p class="eyebrow eyebrow--small">{service.title}</p>
            <h2>{service.summary}</h2>
            <p class="service-problem"><strong>Business problem:</strong> {service.problem}</p>
          </div>

          <div class="service-card__meta">
            <article class="meta-card">
              <p class="meta-card__label">Starting at</p>
              <p class="meta-card__value">{service.startingPrice}</p>
              <p>{service.pricingNote}</p>
            </article>

            <article class="meta-card">
              <p class="meta-card__label">Typical delivery shape</p>
              <p>{service.typicalTimeline}</p>
              <p><strong>Best fit buyer:</strong> {service.bestFor}</p>
            </article>
          </div>

          <div class="service-card__body">
            <article class="service-block">
              <h3>What gets built</h3>
              <ul class="check-list">
                {service.includes.map((item) => <li>{item}</li>)}
              </ul>
            </article>

            <article class="service-block">
              <h3>Common examples</h3>
              <div class="pill-list" role="list">
                {service.examples.map((item) => (
                  <span class="pill" role="listitem">{item}</span>
                ))}
              </div>
            </article>

            <article class="service-block">
              <h3>Typical outcomes</h3>
              <div class="pill-list" role="list">
                {service.outcomes.map((outcome) => (
                  <span class="pill pill--dark" role="listitem">{outcome}</span>
                ))}
              </div>
            </article>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container capability-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">Operational problems</p>
        <h2>Common reasons these projects start</h2>
        <ul class="check-list">
          {operationalProblemsSolved.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Systems commonly built</p>
        <h2>Typical shapes of the work</h2>
        <ul class="check-list">
          {systemsCommonlyBuilt.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>

    <div class="container supporting-card">
      <p class="eyebrow eyebrow--small">Supporting capabilities</p>
      <h2>Technical depth that supports the core offers</h2>
      <div class="pill-list" role="list">
        {supportingCapabilities.map((capability) => (
          <span class="pill pill--dark" role="listitem">{capability}</span>
        ))}
      </div>
    </div>
  </section>

  <BuyerGuide />

  <section class="section-padding cta-band">
    <div class="container cta-band__content">
      <p class="eyebrow">Next step</p>
      <h2>Bring the workflow problem first. The service line can be confirmed from there.</h2>
      <p>
        If you already know where the spreadsheet pain, intake friction, or repetitive admin work is happening,
        that is enough to start a useful scoping conversation.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/process" variant="secondary">See the process</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero,
  .cta-band {
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero {
    padding: 7rem 0 4rem;
  }

  .hero-grid,
  .capability-grid,
  .service-card__meta,
  .service-card__body {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.72fr);
    align-items: start;
  }

  .page-hero__content,
  .cta-band__content {
    max-width: 820px;
  }

  .hero-panel,
  .service-card,
  .panel,
  .supporting-card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .hero-panel {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(18px);
  }

  .hero-panel p {
    margin-bottom: 0;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.9);
  }

  .eyebrow,
  .hero-panel__label,
  .meta-card__label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eyebrow,
  .hero-panel__label {
    color: var(--color-accent);
  }

  .eyebrow--small,
  .meta-card__label {
    color: var(--color-primary);
  }

  .page-hero h1,
  .cta-band h2 {
    color: var(--color-white);
  }

  .page-hero__lead,
  .cta-band p,
  .service-problem,
  .meta-card p,
  .service-block li,
  .panel li {
    line-height: 1.75;
  }

  .page-hero__lead,
  .cta-band p {
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .services-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .service-card {
    background-color: var(--color-white);
  }

  .service-card__meta {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: var(--space-md);
  }

  .meta-card {
    padding: 1rem;
    border-radius: var(--border-radius-sm);
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
    border: 1px solid rgba(42, 157, 143, 0.16);
  }

  .meta-card__value {
    font-size: 1.8rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-dark);
  }

  .service-card__body {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: var(--space-lg);
  }

  .service-block h3,
  .panel h2,
  .supporting-card h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-sm);
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
    color: var(--color-text);
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .section-light {
    background-color: var(--color-white);
  }

  .capability-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel,
  .supporting-card {
    background-color: var(--color-white);
  }

  .supporting-card {
    margin-top: var(--space-lg);
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background-color: rgba(42, 157, 143, 0.08);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.92rem;
  }

  .pill--dark {
    background-color: var(--color-light);
    color: var(--color-dark);
  }

  @media (max-width: 960px) {
    .hero-grid,
    .service-card__meta,
    .service-card__body,
    .capability-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
