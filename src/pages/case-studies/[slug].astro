---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { caseStudies, ctaLabels, primaryCtaHref } from '../../data/siteContent';
import { getWebpVariant } from '../../utils/images';

export function getStaticPaths() {
  return caseStudies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
---

<MainLayout
  title={`${study.title} | Case Study | Beloved John Dev`}
  description={study.summary}
  canonical={`/case-studies/${study.slug}`}
  ogImage={`/og/case-studies/${study.slug}.svg`}
  ogImageAlt={`${study.title} case study share image`}
>
  <Navbar slot="navbar" />

  <section class="page-hero page-hero--case-studies">
    <div class="container hero-grid">
      <div class="page-hero__content">
        <p class="eyebrow">{study.projectType}</p>
        <h1>{study.title}</h1>
        <p class="page-hero__lead">{study.summary}</p>
        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
        </div>
      </div>

      <div class="hero-media">
        <picture>
          <source srcset={getWebpVariant(study.image)} type="image/webp" />
          <img
            src={study.image}
            alt={study.alt}
            width="900"
            height="600"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container content-stack">
      <article class="surface-card">
        <p class="eyebrow">Project Overview</p>
        <h2>What the project was</h2>
        {study.projectOverview.map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <article class="surface-card">
        <p class="eyebrow">Client / Organization Type</p>
        <h2>Who this was for</h2>
        <div class="meta-grid">
          <div>
            <h3>Industry</h3>
            <p>{study.industry}</p>
          </div>
          <div>
            <h3>Company Size</h3>
            <p>{study.companySize}</p>
          </div>
          <div>
            <h3>Project Type</h3>
            <p>{study.projectType}</p>
          </div>
        </div>
      </article>

      <article class="surface-card">
        <p class="eyebrow">The Business Problem</p>
        <h2>The operational pain behind the project</h2>
        <p>{study.businessProblem}</p>
      </article>

      <article class="surface-card">
        <p class="eyebrow">The Old Workflow</p>
        <h2>What was happening before</h2>
        <div class="workflow-list">
          {study.oldWorkflow.map((item) => (
            <div class="workflow-step">
              <p>{item}</p>
            </div>
          ))}
        </div>
      </article>
    </div>
  </section>

  <section class="section-padding detail-band">
    <div class="container grid-2">
      <article class="surface-card">
        <p class="eyebrow">The Goal</p>
        <h2>What the system needed to achieve</h2>
        <ul class="bullet-list">
          {study.goal.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="surface-card">
        <p class="eyebrow">Scope of Work</p>
        <h2>What was included</h2>
        <ul class="bullet-list">
          {study.scopeDelivered.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding">
    <div class="container grid-2">
      <article class="surface-card">
        <p class="eyebrow">System Design / Technical Architecture</p>
        <h2>How the system was structured</h2>
        <p>{study.architectureSummary}</p>
        <ul class="bullet-list">
          {study.technicalShape.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="surface-card">
        <p class="eyebrow">Key Features Built</p>
        <h2>Core functionality delivered</h2>
        <ul class="bullet-list">
          {study.keyFeatures.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding detail-band">
    <div class="container grid-2">
      <article class="surface-card">
        <p class="eyebrow">Constraints & Decisions</p>
        <h2>Important engineering considerations</h2>
        <h3>Constraints</h3>
        <ul class="bullet-list">
          {study.constraints.map((item) => <li>{item}</li>)}
        </ul>
        <h3 class="subheading">Key decisions</h3>
        <ul class="bullet-list">
          {study.keyDecisions.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="surface-card">
        <p class="eyebrow">Outcome / Business Impact</p>
        <h2>How the workflow improved</h2>
        <ul class="bullet-list">
          {study.outcomes.map((item) => <li>{item}</li>)}
        </ul>

        {study.referenceHref ? (
          <p class="reference-line">
            <strong>{study.referenceLabel}:</strong>{' '}
            <a
              href={study.referenceHref}
              target={study.referenceExternal ? '_blank' : undefined}
              rel={study.referenceExternal ? 'noopener nofollow' : undefined}
            >
              {study.referenceText}
            </a>
          </p>
        ) : (
          <p class="reference-line">
            <strong>{study.referenceLabel}:</strong> {study.referenceText}
          </p>
        )}

        {study.confidential && <p class="muted">Some project details are generalized to respect client privacy.</p>}
      </article>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <article class="surface-card">
        <p class="eyebrow">What This Project Demonstrates</p>
        <h2>Why this matters for future clients</h2>
        <ul class="bullet-list">
          {study.demonstrates.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding cta-frame">
    <div class="container cta-frame__content">
      <p class="eyebrow">Call To Action</p>
      <h2>If your business is dealing with similar workflow issues, we should talk.</h2>
      <p>
        If you are dealing with manual intake, weak lead information, disconnected systems, or spreadsheet-heavy
        operations, we can talk about building a tool that fits your workflow.
      </p>
      <div class="hero-actions">
        <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .hero-grid,
  .grid-2,
  .content-stack,
  .meta-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    align-items: start;
  }

  .hero-media img {
    width: 100%;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 16 / 11;
    object-fit: cover;
  }

  .content-stack {
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .meta-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .meta-grid > div {
    padding: 1rem 1.1rem;
    border-radius: var(--border-radius-sm);
    background: rgba(14, 91, 98, 0.04);
    border: 1px solid rgba(14, 91, 98, 0.08);
  }

  .meta-grid h3,
  .subheading {
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
  }

  .meta-grid p {
    margin-bottom: 0;
  }

  .detail-band {
    background: rgba(255, 255, 255, 0.45);
  }

  .workflow-list {
    display: grid;
    gap: 0.9rem;
  }

  .workflow-step {
    position: relative;
    padding: 0.15rem 0 0.15rem 1.4rem;
  }

  .workflow-step::before {
    content: '>';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-primary);
    font-weight: 800;
  }

  .workflow-step p,
  .reference-line {
    margin-bottom: 0;
  }

  .subheading {
    margin-top: var(--space-md);
  }

  .reference-line {
    margin-top: var(--space-md);
  }

  .grid-2 > .surface-card,
  .content-stack > .surface-card {
    height: 100%;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .grid-2,
    .meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
