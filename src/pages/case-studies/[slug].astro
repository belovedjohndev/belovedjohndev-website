---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { caseStudies, ctaLabels } from '../../data/siteContent';

export function getStaticPaths() {
  return caseStudies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
---

<MainLayout
  title={`${study.title} | Case Study | Beloved John Dev`}
  description={study.summary}
  canonical={`/case-studies/${study.slug}`}
  ogImage={`/og/case-studies/${study.slug}.svg`}
  ogImageAlt={`${study.title} case study share image`}
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{study.category}</p>
        <h1>{study.title}</h1>
        <p class="page-hero__lead">{study.summary}</p>
        <p class="page-hero__support"><strong>Best fit:</strong> {study.audience}</p>

        <div class="hero-actions">
          <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
          <Button href="/case-studies" variant="secondary">Back to Case Studies</Button>
        </div>
      </div>

      <div class="hero-media">
        <img src={study.image} alt={study.alt} width="900" height="600" loading="eager" />
      </div>
    </div>
  </section>

  <section class="proof-band">
    <div class="container proof-band__grid">
      {study.proofPoints.map((point) => (
        <article class="proof-band__card">
          <p class="proof-band__value">{point.value}</p>
          <p class="proof-band__label">{point.label}</p>
          <p class="proof-band__detail">{point.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-padding">
    <div class="container detail-grid">
      <article class="detail-card">
        <p class="eyebrow eyebrow--small">Client problem</p>
        <h2>What was not working</h2>
        <p>{study.problem}</p>
      </article>

      <article class="detail-card">
        <p class="eyebrow eyebrow--small">Approach</p>
        <h2>How I shaped the build</h2>
        <p>{study.approach}</p>
      </article>

      <article class="detail-card">
        <p class="eyebrow eyebrow--small">Solution</p>
        <h2>What was built</h2>
        <p>{study.solution}</p>
      </article>

      <article class="detail-card">
        <p class="eyebrow eyebrow--small">Outcome</p>
        <h2>What improved</h2>
        <p>{study.outcome}</p>
      </article>
    </div>
  </section>

  <section class="section-padding section-light">
    <div class="container split-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">Key features</p>
        <h2>System highlights</h2>
        <ul class="check-list">
          {study.features.map((feature) => <li>{feature}</li>)}
        </ul>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Business impact</p>
        <h2>Results and value</h2>
        <ul class="check-list">
          {study.results.map((result) => <li>{result}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding">
    <div class="container split-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">Stack</p>
        <h2>Architecture and tooling</h2>
        <div class="tag-list" role="list">
          {study.stack.map((tag) => (
            <span class="tag" role="listitem">{tag}</span>
          ))}
        </div>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Reference</p>
        <h2>Availability</h2>
        {study.referenceHref ? (
          <p>
            <a
              href={study.referenceHref}
              target={study.referenceExternal === false ? undefined : '_blank'}
              rel={study.referenceExternal === false ? undefined : 'noopener nofollow'}
            >
              {study.referenceText}
            </a>
          </p>
        ) : (
          <p>{study.referenceText}</p>
        )}
        {study.confidential && (
          <p class="text-muted">Some project details are generalized to respect client privacy.</p>
        )}
      </article>
    </div>
  </section>

  <section class="section-padding cta-band">
    <div class="container cta-band__content">
      <p class="eyebrow">Next step</p>
      <h2>Need a Similar System for Your Team?</h2>
      <p>
        If your workflow has similar bottlenecks, we can start with the process problem and map
        the smallest useful version of the system.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/services" variant="secondary">View Service Lines</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero,
  .cta-band {
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero {
    padding: 7rem 0 4rem;
  }

  .proof-band {
    background-color: var(--color-white);
    padding: var(--space-lg) 0;
  }

  .hero-grid,
  .split-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.95fr);
    align-items: center;
  }

  .split-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-lg);
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .eyebrow--small {
    color: var(--color-primary);
  }

  .page-hero h1,
  .cta-band h2 {
    color: var(--color-white);
  }

  .page-hero__lead,
  .page-hero__support,
  .detail-card p,
  .panel p,
  .cta-band p {
    line-height: 1.75;
  }

  .page-hero__lead,
  .page-hero__support,
  .cta-band p {
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .hero-media img {
    width: 100%;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-lg);
  }

  .proof-band__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .proof-band__card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
    border: 1px solid rgba(42, 157, 143, 0.14);
    box-shadow: var(--shadow-sm);
  }

  .proof-band__value {
    margin-bottom: 0.35rem;
    font-size: 1.35rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-dark);
  }

  .proof-band__label {
    margin-bottom: var(--space-xs);
    line-height: 1.5;
    font-weight: 600;
    color: var(--color-text);
  }

  .proof-band__detail {
    margin-bottom: 0;
    line-height: 1.7;
    color: var(--color-text);
  }

  .detail-card,
  .panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .section-light {
    background-color: var(--color-white);
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
    line-height: 1.7;
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    background-color: var(--color-light);
    color: var(--color-dark);
    font-weight: 500;
  }

  .cta-band__content {
    max-width: 820px;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .hero-grid,
    .split-grid,
    .proof-band__grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
