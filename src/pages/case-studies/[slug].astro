---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import JsonLd from '../../components/JsonLd.astro';
import { caseStudies, ctaLabels, primaryCtaHref } from '../../data/siteContent';
import { getWebpVariant, hasWebpVariant } from '../../utils/images';

export function getStaticPaths() {
  return caseStudies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://belovedjohndev.com';
const caseStudyUrl = `${siteUrl}/case-studies/${study.slug}`;
const caseStudyMetaDescription = study.outcomeOneLiner ?? study.summary;
const caseStudyImageUrl = study.image.startsWith('http') ? study.image : `${siteUrl}${study.image}`;

const getStatusLabel = () => {
  if (study.referenceExternal && study.referenceHref) {
    return 'Live demo';
  }

  if (study.confidential) {
    return 'Private build';
  }

  if (study.referenceHref) {
    return 'Related offer';
  }

  return study.referenceLabel;
};

const getReferenceLinkLabel = () => {
  if (!study.referenceHref) {
    return null;
  }

  if (study.referenceExternal && study.referenceLabel.toLowerCase().includes('demo')) {
    return 'View Live Demo';
  }

  return study.referenceText;
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Case Studies',
      item: `${siteUrl}/case-studies`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: study.title,
      item: caseStudyUrl,
    },
  ],
};
const caseStudySchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: study.title,
  name: study.title,
  description: study.summary,
  url: caseStudyUrl,
  image: caseStudyImageUrl,
  articleSection: study.serviceLine,
  about: [study.serviceLine, study.projectType],
  publisher: {
    '@type': 'Organization',
    name: 'Beloved John Dev',
    url: siteUrl,
  },
  inLanguage: 'en',
};
---

<MainLayout
  title={`${study.title} Case Study | Beloved John Dev`}
  description={caseStudyMetaDescription}
  canonical={`/case-studies/${study.slug}`}
  ogImage={`/og/case-studies/${study.slug}.png`}
  ogImageAlt={`${study.title} case study share image`}
>
  <Navbar slot="navbar" />
  <JsonLd data={breadcrumbSchema} />
  <JsonLd data={caseStudySchema} />

  <section class="page-hero page-hero--case-studies">
    <div class="container hero-grid">
      <div class="page-hero__content">
        <div class="tag-row" aria-label="Case study classification">
          <span>{study.serviceLine}</span>
          <span>{getStatusLabel()}</span>
        </div>
        <h1>{study.title}</h1>
        <p class="page-hero__lead">{study.summary}</p>
        <div class="hero-actions">
          <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
          {getReferenceLinkLabel() && study.referenceHref && (
            <Button
              href={study.referenceHref}
              variant="secondary"
              target={study.referenceExternal === false ? undefined : '_blank'}
              rel={study.referenceExternal === false ? undefined : 'noopener'}
            >
              {getReferenceLinkLabel()}
            </Button>
          )}
        </div>
      </div>

      <div class="hero-media">
        <picture>
          {hasWebpVariant(study.image) && <source srcset={getWebpVariant(study.image)} type="image/webp" />}
          <img
            src={study.image}
            alt={study.alt}
            width="900"
            height="600"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </div>
    </div>
  </section>

  {study.screenshots && study.screenshots.length > 0 && (
    <section class="section-padding proof-gallery" aria-labelledby="proof-gallery-heading">
      <div class="container">
        <div class="section-title compact-title">
          <p class="eyebrow">Product proof</p>
          <h2 id="proof-gallery-heading">Screens from the working system.</h2>
        </div>

        <div class="screenshot-grid">
          {study.screenshots.map((screenshot) => (
            <figure class="screenshot-card">
              <img
                src={screenshot.image}
                alt={screenshot.alt}
                width="900"
                height="600"
                loading="lazy"
                decoding="async"
              />
              <figcaption>{screenshot.label}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section-padding context-band" aria-labelledby="project-context-heading">
    <div class="container">
      <div class="section-title compact-title">
        <p class="eyebrow">Project context</p>
        <h2 id="project-context-heading">Compact project facts.</h2>
      </div>

      <div class="context-grid">
        <div class="context-item">
          <p>Industry</p>
          <strong>{study.industry}</strong>
        </div>
        <div class="context-item">
          <p>Company size</p>
          <strong>{study.companySize}</strong>
        </div>
        <div class="context-item">
          <p>Project type</p>
          <strong>{study.projectType}</strong>
        </div>
        <div class="context-item">
          <p>Service line</p>
          <strong>{study.serviceLine}</strong>
        </div>
        <div class="context-item">
          <p>Status / reference</p>
          <strong>{getStatusLabel()}</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container content-stack">
      <article class="surface-card">
        <p class="eyebrow">Before</p>
        <h2>Before the build</h2>
        <p class="section-lead">{study.problemOneLiner}</p>
        <div class="workflow-list">
          {study.oldWorkflow.map((item) => (
            <div class="workflow-step">
              <p>{item}</p>
            </div>
          ))}
        </div>
      </article>

      <article class="surface-card">
        <p class="eyebrow">Build</p>
        <h2>What was built</h2>
        <div class="grid-2">
          <div>
            <h3>Delivered scope</h3>
            <ul class="bullet-list">
              {study.scopeDelivered.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div>
            <h3>Core functionality</h3>
            <ul class="bullet-list">
              {study.keyFeatures.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section-padding detail-band">
    <div class="container content-stack">
      <article class="surface-card">
        <p class="eyebrow">Architecture</p>
        <h2>How the system was structured</h2>
        <p class="section-lead">{study.architectureSummary}</p>
        <ul class="bullet-list architecture-list">
          {study.technicalShape.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="surface-card">
        <p class="eyebrow">Decisions</p>
        <h2>Key decisions</h2>
        <p class="section-lead">
          These choices shaped the build around the workflow problem instead of adding features for their own sake.
        </p>
        <ul class="bullet-list">
          {study.keyDecisions.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding">
    <div class="container grid-2">
      <article class="surface-card">
        <p class="eyebrow">Outcome</p>
        <h2>What changed</h2>
        <p class="section-lead">{study.outcomeOneLiner}</p>
        <ul class="bullet-list">
          {study.outcomes.map((item) => <li>{item}</li>)}
        </ul>

        {study.referenceHref ? (
          <p class="reference-line">
            <strong>{study.referenceLabel}:</strong>{' '}
            <a
              href={study.referenceHref}
              target={study.referenceExternal ? '_blank' : undefined}
              rel={study.referenceExternal ? 'noopener' : undefined}
            >
              {study.referenceText}
            </a>
          </p>
        ) : (
          <p class="reference-line">
            <strong>{study.referenceLabel}:</strong> {study.referenceText}
          </p>
        )}

        {study.confidential && <p class="muted">Some project details are generalized to respect client privacy.</p>}
      </article>

      <article class="surface-card">
        <p class="eyebrow">Buyer trust</p>
        <h2>What this demonstrates</h2>
        <ul class="bullet-list">
          {study.demonstrates.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section-padding cta-frame">
    <div class="container cta-frame__content">
      <p class="eyebrow">Next step</p>
      <h2>Working through a similar workflow problem?</h2>
      <p>
        Start with the current process, where it breaks down, and what should be better after the first phase.
      </p>
      <div class="hero-actions">
        <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .hero-grid,
  .grid-2,
  .content-stack,
  .context-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    align-items: start;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .tag-row span {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .hero-media img {
    width: 100%;
    max-height: 34rem;
    border-radius: var(--border-radius);
    border: 1px solid rgba(16, 32, 51, 0.12);
    box-shadow: var(--shadow-md);
    aspect-ratio: 16 / 10;
    object-fit: contain;
    object-position: center;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 246, 247, 0.96)),
      radial-gradient(circle at top left, rgba(216, 161, 93, 0.14), transparent 32%);
    padding: clamp(0.75rem, 1.8vw, 1.2rem);
  }

  .page-hero h1 {
    overflow-wrap: anywhere;
  }

  .context-band,
  .detail-band,
  .proof-gallery {
    background: rgba(255, 255, 255, 0.45);
  }

  .compact-title {
    max-width: 720px;
  }

  .context-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .context-item {
    min-width: 0;
    padding: 0.95rem 1rem;
    border-radius: var(--border-radius-sm);
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(16, 32, 51, 0.09);
  }

  .context-item p,
  .context-item strong {
    margin-bottom: 0;
  }

  .context-item p {
    margin-bottom: 0.3rem;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .context-item strong {
    display: block;
    color: var(--color-dark);
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .content-stack {
    grid-template-columns: 1fr;
    gap: 1.35rem;
  }

  .screenshot-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .screenshot-card {
    display: grid;
    gap: 0.8rem;
    margin: 0;
  }

  .screenshot-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    object-position: center top;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(16, 32, 51, 0.1);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 4px 14px rgba(16, 32, 51, 0.06);
  }

  .screenshot-card figcaption {
    color: var(--color-text-muted);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-2 h3 {
    margin-bottom: 0.65rem;
    font-size: 1.05rem;
  }

  .section-lead {
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .workflow-list {
    display: grid;
    gap: 0.7rem;
  }

  .workflow-step {
    position: relative;
    padding: 0.85rem 0.95rem 0.85rem 1.1rem;
    border-radius: var(--border-radius-sm);
    background: rgba(244, 246, 247, 0.74);
    border: 1px solid rgba(16, 32, 51, 0.08);
    border-left: 3px solid rgba(14, 91, 98, 0.32);
  }

  .workflow-step::before {
    content: none;
  }

  .workflow-step p,
  .reference-line {
    margin-bottom: 0;
  }

  .architecture-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .reference-line {
    margin-top: var(--space-md);
  }

  .grid-2 > .surface-card,
  .content-stack > .surface-card {
    height: 100%;
  }

  @media (max-width: 1100px) {
    .context-grid,
    .screenshot-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .hero-grid,
    .grid-2,
    .context-grid,
    .architecture-list,
    .screenshot-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
