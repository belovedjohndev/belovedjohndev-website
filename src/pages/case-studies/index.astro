---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { caseStudies, ctaLabels, primaryCtaHref } from '../../data/siteContent';
import { getWebpVariant, hasWebpVariant } from '../../utils/images';
---

<MainLayout
  title="Case Studies | Beloved John Dev"
  description="Systems-focused case studies showing workflow problems, architecture decisions, and business impact."
  canonical="/case-studies"
  ogImage="/og/case-studies.svg"
  ogImageAlt="Beloved John Dev case studies page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero page-hero--case-studies">
    <div class="container page-hero__content">
      <p class="eyebrow">Case Studies</p>
      <h1>Case studies written like systems work, not portfolio captions</h1>
      <p class="page-hero__lead">
        These projects are structured around workflow pain, goals, scope, architecture, decisions, and business
        impact so future clients can see both technical depth and operational judgment.
      </p>
      <div class="hero-actions">
        <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
        <Button href="#case-list" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <section class="section-padding" id="case-list">
    <div class="container case-study-grid">
      {caseStudies.map((study) => (
        <article class="surface-card case-study-card">
          <div class="case-study-media">
            <picture>
              {hasWebpVariant(study.image) && <source srcset={getWebpVariant(study.image)} type="image/webp" />}
              <img src={study.image} alt={study.alt} width="900" height="600" loading="lazy" decoding="async" />
            </picture>
          </div>
          <div class="case-study-content">
            <p class="eyebrow">{study.projectType}</p>
            <h2>{study.title}</h2>
            <p>{study.summary}</p>
            <p class="muted case-study-meta">
              <strong>Industry:</strong> {study.industry} | <strong>Company size:</strong> {study.companySize}
            </p>
            <div class="chip-row">
              {study.proof.map((item) => (
                <span class="chip">{item}</span>
              ))}
            </div>
            <div class="case-study-actions">
              <Button href={`/case-studies/${study.slug}`} variant="dark">Read Case Study</Button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-padding cta-frame">
    <div class="container cta-frame__content">
      <p class="eyebrow">Next step</p>
      <h2>If one of these workflow problems feels familiar, that is enough to start a conversation.</h2>
      <p>
        The point of these case studies is to help serious buyers self-qualify. If the operational pain matches,
        we can define a tool or system that fits your workflow.
      </p>
      <div class="hero-actions">
        <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
        <Button href="#case-list" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .case-study-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .case-study-card {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    padding: 0;
  }

  .case-study-media {
    display: grid;
    place-items: center;
    min-height: 260px;
    padding: 1rem;
    background:
      linear-gradient(180deg, rgba(244, 246, 247, 0.96), rgba(233, 239, 242, 0.96)),
      radial-gradient(circle at top left, rgba(216, 161, 93, 0.14), transparent 30%);
    border-bottom: 1px solid rgba(16, 32, 51, 0.08);
  }

  .case-study-media picture {
    width: 100%;
  }

  .case-study-media img {
    width: 100%;
    height: 100%;
    max-height: 320px;
    object-fit: contain;
    object-position: center;
  }

  .case-study-content {
    display: grid;
    grid-template-rows: auto auto auto auto auto 1fr;
    gap: 1rem;
    padding: var(--space-lg);
  }

  .case-study-content h2 {
    overflow-wrap: anywhere;
  }

  .case-study-content p,
  .case-study-content h2 {
    margin-bottom: 0;
  }

  .case-study-meta {
    padding-bottom: 0.1rem;
    border-bottom: 1px solid rgba(16, 32, 51, 0.08);
  }

  .case-study-actions {
    align-self: start;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .case-study-actions :global(.btn) {
    width: 100%;
  }

  @media (max-width: 900px) {
    .case-study-grid {
      grid-template-columns: 1fr;
    }

    .case-study-media {
      min-height: 220px;
    }
  }
</style>
