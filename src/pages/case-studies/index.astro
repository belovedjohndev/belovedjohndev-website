---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { caseStudies, ctaLabels } from '../../data/siteContent';
---

<MainLayout
  title="Case Studies | Beloved John Dev"
  description="Case studies showing business systems, estimator tools, and operational websites built around real workflow problems."
  canonical="/case-studies"
  ogImage="/og/case-studies.svg"
  ogImageAlt="Beloved John Dev case studies share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">Case Studies</p>
      <h1>Proof Built Around Business Problems, Not Just Screenshots</h1>
      <p class="page-hero__lead">
        Each project is framed around the same questions a serious client asks:
        what was broken, what was built, and what improved.
      </p>
      <p class="page-hero__lead">
        Use these as decision support, not just portfolio pieces. They are here to show how the work is scoped and what kind of business value the systems are meant to create.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/services" variant="secondary">View Service Lines</Button>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container case-study-grid">
      {caseStudies.map((study) => (
        <article class="case-study-card">
          <img src={study.image} alt={study.alt} width="900" height="600" loading="lazy" class="case-study-image" />
          <div class="case-study-card__body">
            <p class="eyebrow eyebrow--small">{study.category}</p>
            <h2>{study.title}</h2>
            <p class="case-study-summary">{study.summary}</p>

            <div class="proof-grid">
              {study.proofPoints.map((point) => (
                <article class="proof-card">
                  <p class="proof-card__value">{point.value}</p>
                  <p class="proof-card__label">{point.label}</p>
                </article>
              ))}
            </div>

            <div class="case-study-block">
              <h3>Problem</h3>
              <p>{study.problem}</p>
            </div>

            <div class="case-study-block">
              <h3>Result</h3>
              <ul class="result-list">
                {study.results.map((result) => <li>{result}</li>)}
              </ul>
            </div>

            <div class="tag-list" role="list">
              {study.stack.map((tag) => (
                <span class="tag" role="listitem">{tag}</span>
              ))}
            </div>

            <div class="case-study-actions">
              <a href={`/case-studies/${study.slug}`} class="text-link">Read the case study</a>
              {study.referenceHref ? (
                <a
                  href={study.referenceHref}
                  target={study.referenceExternal === false ? undefined : '_blank'}
                  rel={study.referenceExternal === false ? undefined : 'noopener nofollow'}
                  class="text-link"
                >
                  {study.referenceText}
                </a>
              ) : (
                <span class="text-muted">{study.referenceText}</span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero {
    padding: 7rem 0 4rem;
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero__content {
    max-width: 820px;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .eyebrow--small {
    color: var(--color-primary);
  }

  .page-hero h1 {
    color: var(--color-white);
  }

  .page-hero__lead {
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-actions,
  .case-study-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero-actions {
    margin-top: var(--space-lg);
  }

  .case-study-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .case-study-card {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.2fr);
    gap: var(--space-lg);
    align-items: start;
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .case-study-image {
    width: 100%;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-sm);
  }

  .case-study-summary,
  .case-study-block p {
    line-height: 1.75;
    color: var(--color-text);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .proof-card {
    padding: var(--space-sm);
    border-radius: var(--border-radius-sm);
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
    border: 1px solid rgba(42, 157, 143, 0.12);
  }

  .proof-card__value {
    margin-bottom: 0.2rem;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-dark);
  }

  .proof-card__label {
    margin-bottom: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-text);
  }

  .case-study-block {
    margin-top: var(--space-md);
  }

  .case-study-block h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
  }

  .result-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .result-list li {
    position: relative;
    padding-left: var(--space-md);
    line-height: 1.7;
  }

  .result-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .tag {
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background-color: var(--color-light);
    color: var(--color-dark);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .case-study-actions {
    margin-top: var(--space-md);
  }

  .text-link {
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .case-study-card {
      grid-template-columns: 1fr;
    }

    .proof-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
