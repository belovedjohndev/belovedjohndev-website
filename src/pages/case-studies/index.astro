---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/ui/Button.astro';
import { caseStudies, ctaLabels } from '../../data/siteContent';
---

<MainLayout
  title="Case Studies | Beloved John Dev"
  description="Systems-focused case studies showing workflow problems, architecture decisions, and business impact."
  canonical="/case-studies"
  ogImage="/og/case-studies.svg"
  ogImageAlt="Beloved John Dev case studies page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">Case Studies</p>
      <h1>Case studies written like systems work, not portfolio captions</h1>
      <p class="page-hero__lead">
        These projects are structured around workflow pain, goals, scope, architecture, decisions, and business
        impact so future clients can see both technical depth and operational judgment.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="#case-list" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <section class="section-padding" id="case-list">
    <div class="container case-grid">
      {caseStudies.map((study) => (
        <article class="surface-card case-card">
          <img src={study.image} alt={study.alt} width="900" height="600" loading="lazy" />
          <div class="case-card__body">
            <p class="eyebrow">{study.projectType}</p>
            <h2>{study.title}</h2>
            <p>{study.summary}</p>
            <p class="muted case-card__meta">
              <strong>Industry:</strong> {study.industry} | <strong>Company size:</strong> {study.companySize}
            </p>
            <div class="chip-row">
              {study.proof.map((item) => (
                <span class="chip">{item}</span>
              ))}
            </div>
            <Button href={`/case-studies/${study.slug}`} variant="dark">Read Case Study</Button>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-padding cta-frame">
    <div class="container cta-frame__content">
      <p class="eyebrow">Next step</p>
      <h2>If one of these workflow problems feels familiar, that is enough to start a conversation.</h2>
      <p>
        The point of these case studies is to help serious buyers self-qualify. If the operational pain matches,
        we can define a tool or system that fits your workflow.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="#case-list" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .case-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .case-card {
    display: grid;
    grid-template-columns: minmax(300px, 0.95fr) minmax(0, 1.1fr);
    gap: var(--space-lg);
    overflow: hidden;
    padding: 0;
  }

  .case-card img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
  }

  .case-card__body {
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: var(--space-lg);
  }

  .case-card__meta {
    padding-bottom: 0.1rem;
    border-bottom: 1px solid rgba(16, 32, 51, 0.08);
  }

  .case-card__body :global(.btn) {
    align-self: start;
    margin-top: 0.25rem;
  }

  @media (max-width: 900px) {
    .case-card {
      grid-template-columns: 1fr;
    }

    .case-card img {
      min-height: 220px;
    }
  }
</style>
