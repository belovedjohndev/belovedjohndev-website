---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import AboutSection from '../components/sections/About.astro';
import WhyMe from '../components/sections/WhyMe.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import { aboutPrinciples, ctaLabels, engagementModel } from '../data/siteContent';
---

<MainLayout
  title="About | Beloved John Dev"
  description="Independent business systems studio focused on practical, maintainable software for operationally serious clients."
  canonical="/about"
  ogImage="/og/about.svg"
  ogImageAlt="Beloved John Dev about page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero">
    <div class="container page-hero__content">
      <p class="eyebrow">About</p>
      <h1>Independent consultant mindset, boutique systems delivery</h1>
      <p class="page-hero__lead">
        The value here is not sounding like an agency. It is understanding the workflow underneath the request
        and turning it into software that stays useful after launch.
      </p>
      <div class="hero-actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <AboutSection />

  <section class="section-padding section-light">
    <div class="container split-grid">
      <article class="panel">
        <p class="eyebrow eyebrow--small">Working principles</p>
        <div class="principles-grid">
          {aboutPrinciples.map((principle) => (
            <article class="principle-card">
              <h2>{principle.title}</h2>
              <p>{principle.description}</p>
            </article>
          ))}
        </div>
      </article>

      <article class="panel">
        <p class="eyebrow eyebrow--small">Engagement model</p>
        <h2>How I prefer to structure the work</h2>
        <div class="engagement-list">
          {engagementModel.map((item) => (
            <article class="engagement-item">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </article>
    </div>
  </section>

  <WhyMe />
  <Testimonials />

  <Footer slot="footer" />
</MainLayout>

<style>
  .page-hero {
    padding: 7rem 0 4rem;
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.16), transparent 24%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.94), rgba(17, 50, 64, 0.9)),
      url('/assets/images/hero-bg.png');
    background-position: center;
    background-size: cover;
  }

  .page-hero__content {
    max-width: 820px;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .eyebrow--small {
    color: var(--color-primary);
  }

  .page-hero h1 {
    color: var(--color-white);
  }

  .page-hero__lead {
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .section-light {
    background-color: var(--color-white);
  }

  .split-grid,
  .principles-grid,
  .engagement-list {
    display: grid;
    gap: var(--space-lg);
  }

  .split-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel,
  .principle-card,
  .engagement-item {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .principles-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: var(--space-md);
  }

  .engagement-list {
    margin-top: var(--space-md);
  }

  .principle-card h2,
  .engagement-item h3 {
    font-size: 1.15rem;
  }

  .principle-card p,
  .engagement-item p {
    margin-bottom: 0;
    line-height: 1.75;
    color: var(--color-text);
  }

  @media (max-width: 900px) {
    .split-grid,
    .principles-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 6rem 0 3rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
