---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import { aboutPrinciples, ctaLabels, primaryCtaHref } from '../data/siteContent';
---

<MainLayout
  title="About John Paul | Beloved John Dev"
  description="Independent custom business systems developer focused on practical, maintainable software for operations-heavy teams."
  canonical="/about"
  ogImage="/og/about.svg"
  ogImageAlt="Beloved John Dev about page share image"
>
  <Navbar slot="navbar" />

  <section class="page-hero page-hero--about">
    <div class="container page-hero__content">
      <p class="eyebrow">About</p>
      <h1>Independent developer for custom business systems and workflow software.</h1>
      <p class="page-hero__lead">
        The best fit is a company that needs software shaped around a real workflow and wants direct access to the
        person designing, building, and improving the system.
      </p>
      <div class="hero-actions">
        <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container grid-2">
      <article class="surface-card">
        <p class="eyebrow">Positioning</p>
        <h2>Focused on operational software, not generic web work.</h2>
        <p>
          I work with service companies and operations-heavy teams that need internal systems, client portals,
          estimator tools, dashboards, booking flows, or automation connected to the way the business actually runs.
        </p>
      </article>

      <article class="surface-card">
        <p class="eyebrow">Working style</p>
        <h2>Direct communication and practical scope choices</h2>
        <p>
          Clients should get clear thinking before and during the build. That means honest fit feedback, focused first
          phases, and system decisions that stay tied to business value.
        </p>
      </article>
    </div>
  </section>

  <section class="section-padding principle-band">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">Principles</p>
        <h2>What shapes the work</h2>
      </div>

      <div class="grid-2">
        {aboutPrinciples.map((item) => (
          <article class="surface-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding cta-frame">
    <div class="container cta-frame__content">
      <p class="eyebrow">Next step</p>
      <h2>If the project touches operations, handoffs, or lead quality, it is probably worth a conversation.</h2>
      <p>
        The easiest way to tell whether there is a fit is to start with the current workflow, not a polished
        specification.
      </p>
      <div class="hero-actions">
        <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>

<style>
  .principle-band {
    background: rgba(255, 255, 255, 0.45);
  }
</style>
