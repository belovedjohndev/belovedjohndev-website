---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import BuyerGuide from '../components/sections/BuyerGuide.astro';
import Projects from '../components/sections/Projects.astro';
import WhyMe from '../components/sections/WhyMe.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import FAQ from '../components/sections/FAQ.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';
import Button from '../components/ui/Button.astro';
import {
  ctaLabels,
  engagementModel,
  insights,
  operationalProblemsSolved,
  processSteps,
  systemsCommonlyBuilt,
} from '../data/siteContent';
---

<MainLayout
  title="Beloved John Dev | Custom Business Systems for Operationally Serious Teams"
  description="Custom business systems that replace spreadsheets, manual workflows, and disconnected tools for service businesses, agencies, and growing teams."
  ogImage="/og/home.svg"
  ogImageAlt="Beloved John Dev business systems homepage share image"
>
  <Navbar slot="navbar" />

  <Hero />

  <section class="diagnostic section-padding">
    <div class="container">
      <div class="section-title">
        <p class="section-eyebrow">Operational focus</p>
        <h2>This business is built around workflow problems, not generic web projects</h2>
        <p>
          The strongest fit is when the business already feels the cost of manual handling, scattered data,
          weak lead qualification, or tools that no longer reflect how the team actually works.
        </p>
      </div>

      <div class="diagnostic-grid">
        <article class="diagnostic-card">
          <p class="diagnostic-card__label">Operational problems I solve</p>
          <ul class="check-list">
            {operationalProblemsSolved.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="diagnostic-card">
          <p class="diagnostic-card__label">Systems I commonly build</p>
          <ul class="check-list">
            {systemsCommonlyBuilt.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>

      <div class="engagement-grid">
        {engagementModel.map((item) => (
          <article class="engagement-card">
            <p class="engagement-card__title">{item.title}</p>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Services />
  <BuyerGuide />
  <Projects />

  <section class="process-preview section-padding">
    <div class="container">
      <div class="section-title">
        <p class="section-eyebrow">Delivery</p>
        <h2>What the project path usually looks like</h2>
        <p>Clear discovery, practical scoping, and delivery built around the workflow that needs fixing first.</p>
      </div>

      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-card">
            <p class="process-card__number">{step.number}</p>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>

      <div class="process-actions">
        <Button href="/process" variant="dark">See the full process</Button>
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
      </div>
    </div>
  </section>

  <section class="insights-preview section-padding">
    <div class="container">
      <div class="section-title">
        <p class="section-eyebrow">Decision support</p>
        <h2>Insights for buyers deciding whether custom systems work is the right move</h2>
        <p>These articles are here to help prospects think clearly about workflow bottlenecks, lead quality, and software fit before the first call.</p>
      </div>

      <div class="insights-preview__grid">
        {insights.slice(0, 3).map((article) => (
          <article class="insight-preview-card">
            <p class="insight-preview-card__meta">{article.category} | {article.readingTime}</p>
            <h3>{article.title}</h3>
            <p>{article.summary}</p>
            <a href={`/insights/${article.slug}`}>Read the insight</a>
          </article>
        ))}
      </div>

      <div class="process-actions">
        <Button href="/insights" variant="dark">View all insights</Button>
        <Button href="/services" variant="primary">{ctaLabels.services}</Button>
      </div>
    </div>
  </section>

  <WhyMe />
  <Testimonials />
  <FAQ />
  <ContactCTA />

  <Footer slot="footer" />
</MainLayout>

<style>
  .section-eyebrow,
  .diagnostic-card__label,
  .engagement-card__title,
  .process-card__number,
  .insight-preview-card__meta {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-eyebrow,
  .diagnostic-card__label,
  .engagement-card__title,
  .process-card__number,
  .insight-preview-card__meta {
    color: var(--color-primary);
  }

  .diagnostic {
    background-color: var(--color-white);
  }

  .diagnostic-grid,
  .engagement-grid,
  .process-grid,
  .insights-preview__grid {
    display: grid;
    gap: var(--space-lg);
  }

  .diagnostic-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .engagement-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: var(--space-lg);
  }

  .process-grid {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .insights-preview {
    background-color: var(--color-light);
  }

  .insights-preview__grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .diagnostic-card,
  .engagement-card,
  .process-card,
  .insight-preview-card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .engagement-card {
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li,
  .engagement-card p,
  .process-card p,
  .insight-preview-card p {
    line-height: 1.75;
    color: var(--color-text);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .insight-preview-card a {
    font-weight: 600;
  }

  .process-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-xl);
  }

  @media (max-width: 900px) {
    .diagnostic-grid,
    .engagement-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .process-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
