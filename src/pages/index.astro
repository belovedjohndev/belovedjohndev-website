---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import Projects from '../components/sections/Projects.astro';
import WhyMe from '../components/sections/WhyMe.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import FAQ from '../components/sections/FAQ.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';
import Button from '../components/ui/Button.astro';
import { idealClients, insights, notIdealClients, processSteps } from '../data/siteContent';
---

<MainLayout
  title="Beloved John Dev | Independent Business Systems Developer"
  description="Custom business systems, client portals, and automation software for companies that have outgrown spreadsheets and manual workflows."
  ogImage="/og/home.svg"
  ogImageAlt="Beloved John Dev business systems homepage share image"
>
  <Navbar slot="navbar" />

  <Hero />
  <section class="positioning-band">
    <div class="container positioning-band__content">
      <p class="positioning-band__eyebrow">What I actually help with</p>
      <p class="positioning-band__text">
        I am not primarily selling brochure websites. I help companies replace spreadsheet-heavy workflows,
        disconnected tools, and repetitive admin work with custom software that fits how the business already runs.
      </p>
    </div>
  </section>
  <section class="fit section-padding">
    <div class="container">
      <div class="fit-grid">
        <article class="fit-panel">
          <p class="fit-panel__eyebrow">Best fit</p>
          <h2>Who This Is For</h2>
          <p class="fit-panel__intro">
            This site is built to attract businesses with real operational friction, not one-off design-only projects.
          </p>
          <ul class="fit-list">
            {idealClients.map((client) => <li>{client}</li>)}
          </ul>
        </article>

        <article class="fit-panel fit-panel--muted">
          <p class="fit-panel__eyebrow">Usually not a fit</p>
          <h2>What I Am Not Selling</h2>
          <p class="fit-panel__intro">
            De-emphasizing lower-value web work keeps the positioning focused on systems, portals, and automation.
          </p>
          <ul class="fit-list">
            {notIdealClients.map((client) => <li>{client}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>
  <Services />
  <Projects />
  <section class="process-preview section-padding">
    <div class="container">
      <div class="section-title">
        <h2>How Projects Move</h2>
        <p>Clear discovery, sensible scope, and delivery built around the workflow that needs fixing first.</p>
      </div>

      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-card">
            <p class="process-card__number">{step.number}</p>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>

      <div class="process-actions">
        <Button href="/process" variant="dark">See the Full Process</Button>
      </div>
    </div>
  </section>
  <section class="insights-preview section-padding">
    <div class="container">
      <div class="section-title">
        <h2>How I Think About Systems Work</h2>
        <p>Short insights on workflow bottlenecks, lead quality, and when custom software actually makes sense.</p>
      </div>

      <div class="insights-preview__grid">
        {insights.slice(0, 3).map((article) => (
          <article class="insight-preview-card">
            <p class="insight-preview-card__meta">{article.category} | {article.readingTime}</p>
            <h3>{article.title}</h3>
            <p>{article.summary}</p>
            <a href={`/insights/${article.slug}`}>Read the insight</a>
          </article>
        ))}
      </div>

      <div class="process-actions">
        <Button href="/insights" variant="dark">View All Insights</Button>
      </div>
    </div>
  </section>
  <WhyMe />
  <Testimonials />
  <FAQ />
  <ContactCTA />

  <Footer slot="footer" />
</MainLayout>

<style>
  .positioning-band {
    background-color: var(--color-dark);
    color: var(--color-white);
    padding: var(--space-lg) 0;
  }

  .positioning-band__content {
    max-width: 900px;
  }

  .positioning-band__eyebrow {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .positioning-band__text {
    margin-bottom: 0;
    line-height: 1.75;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.92);
  }

  .fit {
    background-color: var(--color-white);
  }

  .fit-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .fit-panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    border: 1px solid rgba(38, 70, 83, 0.08);
    background-color: var(--color-white);
    box-shadow: var(--shadow-md);
  }

  .fit-panel--muted {
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
  }

  .fit-panel__eyebrow,
  .process-card__number {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .fit-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .fit-panel__intro {
    margin-bottom: var(--space-md);
    color: var(--color-text);
    line-height: 1.75;
  }

  .fit-list li,
  .process-card p {
    color: var(--color-text);
    line-height: 1.7;
  }

  .fit-list li {
    position: relative;
    padding-left: var(--space-md);
  }

  .fit-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .process-preview {
    background-color: var(--color-white);
  }

  .insights-preview {
    background-color: var(--color-light);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-lg);
  }

  .insights-preview__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-lg);
  }

  .process-card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    border: 1px solid rgba(38, 70, 83, 0.08);
    background-color: var(--color-light);
    box-shadow: var(--shadow-sm);
  }

  .insight-preview-card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-sm);
  }

  .insight-preview-card__meta {
    margin-bottom: var(--space-sm);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .insight-preview-card p {
    line-height: 1.7;
    color: var(--color-text);
  }

  .insight-preview-card a {
    font-weight: 600;
  }

  .process-card h3 {
    font-size: 1.15rem;
  }

  .process-actions {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 768px) {
    .fit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
