---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import Projects from '../components/sections/Projects.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';
import Button from '../components/ui/Button.astro';
import {
  buyerGuidance,
  ctaLabels,
  idealClients,
  insights,
  nextStepTimeline,
  processSteps,
  serviceOffers,
} from '../data/siteContent';
---

<MainLayout
  title="Beloved John Dev | Custom Business Systems for Operationally Serious Teams"
  description="Custom business systems that replace spreadsheets, manual workflows, and disconnected tools for service businesses, agencies, and growing teams."
  ogImage="/og/home.svg"
  ogImageAlt="Beloved John Dev business systems homepage share image"
>
  <Navbar slot="navbar" />

  <Hero />

  <section class="qualification-preview section-padding">
    <div class="container">
      <div class="section-title">
        <p class="section-eyebrow">Quick qualification</p>
        <h2>The homepage version of what serious buyers usually need to know</h2>
        <p>
          The full detail lives on the services, process, and contact pages. This section is here to make the first decision easier without turning the homepage into the whole site.
        </p>
      </div>

      <div class="qualification-grid">
        <article class="qualification-card">
          <p class="qualification-card__label">Best fit</p>
          <ul class="check-list">
            {idealClients.slice(0, 4).map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="qualification-card">
          <p class="qualification-card__label">Typical project shape</p>
          <div class="stack-list">
            {buyerGuidance.projectShape.map((item) => (
              <p class="stack-list__item">{item}</p>
            ))}
          </div>
        </article>

        <article class="qualification-card qualification-card--accent">
          <p class="qualification-card__label">Starting ranges</p>
          <div class="price-list">
            {serviceOffers.map((offer) => (
              <div class="price-row">
                <span>{offer.title}</span>
                <strong>{offer.startingPrice}</strong>
              </div>
            ))}
          </div>
          <p class="qualification-note">Final scope depends on workflow complexity, integrations, and business rules.</p>
        </article>

        <article class="qualification-card">
          <p class="qualification-card__label">After inquiry</p>
          <div class="timeline-mini">
            {nextStepTimeline.map((item) => (
              <div class="timeline-mini__item">
                <span>{item.step}</span>
                <p>{item.title}</p>
              </div>
            ))}
          </div>
          <a href="/contact" class="qualification-link">See the full contact process</a>
        </article>
      </div>
    </div>
  </section>

  <Services />
  <Projects />

  <section class="process-preview section-padding">
    <div class="container">
      <div class="section-title">
        <p class="section-eyebrow">Delivery</p>
        <h2>What the project path usually looks like</h2>
        <p>Clear discovery, practical scoping, and delivery built around the workflow that needs fixing first.</p>
      </div>

      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-card">
            <p class="process-card__number">{step.number}</p>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>

      <div class="process-actions">
        <Button href="/process" variant="dark">See the full process</Button>
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
      </div>
    </div>
  </section>

  <section class="insights-preview section-padding">
    <div class="container">
      <div class="section-title">
        <p class="section-eyebrow">Decision support</p>
        <h2>Insights for buyers deciding whether custom systems work is the right move</h2>
        <p>These articles are here to help prospects think clearly about workflow bottlenecks, lead quality, and software fit before the first call.</p>
      </div>

      <div class="insights-preview__grid">
        {insights.slice(0, 3).map((article) => (
          <article class="insight-preview-card">
            <p class="insight-preview-card__meta">{article.category} | {article.readingTime}</p>
            <h3>{article.title}</h3>
            <p>{article.summary}</p>
            <a href={`/insights/${article.slug}`}>Read the insight</a>
          </article>
        ))}
      </div>

      <div class="process-actions">
        <Button href="/insights" variant="dark">View all insights</Button>
        <Button href="/services" variant="primary">{ctaLabels.services}</Button>
      </div>
    </div>
  </section>

  <Testimonials />
  <ContactCTA />

  <Footer slot="footer" />
</MainLayout>

<style>
  .section-eyebrow,
  .qualification-card__label,
  .process-card__number,
  .insight-preview-card__meta {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-eyebrow,
  .qualification-card__label,
  .process-card__number,
  .insight-preview-card__meta {
    color: var(--color-primary);
  }

  .qualification-preview {
    background-color: var(--color-white);
  }

  .qualification-grid,
  .process-grid,
  .insights-preview__grid {
    display: grid;
    gap: var(--space-lg);
  }

  .qualification-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .process-grid {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .insights-preview {
    background-color: var(--color-light);
  }

  .insights-preview__grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .qualification-card,
  .process-card,
  .insight-preview-card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .qualification-card--accent {
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li,
  .stack-list__item,
  .qualification-note,
  .process-card p,
  .insight-preview-card p {
    line-height: 1.75;
    color: var(--color-text);
  }

  .stack-list {
    display: grid;
    gap: var(--space-sm);
  }

  .stack-list__item {
    margin-bottom: 0;
    padding: 0.9rem 1rem;
    border-radius: var(--border-radius-sm);
    background-color: var(--color-light);
    border: 1px solid rgba(42, 157, 143, 0.08);
  }

  .price-list,
  .timeline-mini {
    display: grid;
    gap: var(--space-sm);
  }

  .price-row,
  .timeline-mini__item {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    align-items: center;
    padding: 0.8rem 0.95rem;
    border-radius: var(--border-radius-sm);
    background-color: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(42, 157, 143, 0.12);
  }

  .price-row span,
  .timeline-mini__item p {
    margin-bottom: 0;
    color: var(--color-text);
    line-height: 1.45;
  }

  .price-row strong {
    color: var(--color-dark);
    white-space: nowrap;
  }

  .timeline-mini__item span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background-color: var(--color-primary);
    color: var(--color-white);
    font-size: 0.78rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .qualification-link {
    display: inline-flex;
    margin-top: var(--space-md);
    font-weight: 600;
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .insight-preview-card a {
    font-weight: 600;
  }

  .process-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-xl);
  }

  @media (max-width: 900px) {
    .qualification-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .process-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
