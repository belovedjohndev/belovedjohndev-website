---
import { processSteps, whyWorkWithMe } from '../../data/siteContent';

const processDifferentiators = whyWorkWithMe.slice(0, 2);
---

<section class="section-padding process-band">
  <div class="container">
    <div class="section-title">
      <p class="eyebrow">How It Works</p>
      <h2>A direct, scoped-first working model.</h2>
    </div>

    <div class="grid-2">
      {processSteps.map((step) => (
        <article class="surface-card process-card">
          <p class="eyebrow">{step.number}</p>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>

    <div class="grid-2 process-differentiators" aria-label="Working model differentiators">
      {processDifferentiators.map((item) => (
        <article class="simple-card process-differentiator">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>

    <p class="process-close">
      The goal is to build something useful early, then improve it with real feedback.
    </p>
  </div>
</section>

<style>
  .process-band {
    background: rgba(255, 255, 255, 0.45);
  }

  .process-card p:last-child,
  .process-differentiator p,
  .process-close {
    margin-bottom: 0;
  }

  .process-differentiators {
    margin-top: var(--space-lg);
  }

  .process-differentiator {
    border-left: none;
  }

  .process-close {
    margin-top: var(--space-lg);
    color: var(--color-text-muted);
    font-weight: 700;
  }
</style>
