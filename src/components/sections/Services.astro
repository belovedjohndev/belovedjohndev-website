---
import Button from '../ui/Button.astro';
import { ctaLabels, serviceOffers, supportingCapabilities } from '../../data/siteContent';
---

<section class="services section-padding" id="services">
  <div class="container">
    <div class="section-title">
      <p class="section-eyebrow">Service lines</p>
      <h2>Three focused ways to buy the work</h2>
      <p>
        These offers are designed to help serious clients identify the right starting point quickly.
        They are built around business problems, not a generic list of technologies.
      </p>
    </div>

    <div class="services-grid">
      {serviceOffers.map((service) => (
        <article class="service-card">
          <div class="service-card__top">
            <p class="service-card__eyebrow">{service.title}</p>
            <h3>{service.summary}</h3>
            <p class="service-card__problem"><strong>Business problem:</strong> {service.problem}</p>
          </div>

          <div class="service-meta">
            <div class="service-meta__item">
              <span class="service-meta__label">Starting at</span>
              <strong>{service.startingPrice}</strong>
            </div>
            <div class="service-meta__item">
              <span class="service-meta__label">Delivery shape</span>
              <strong>{service.typicalTimeline}</strong>
            </div>
          </div>

          <div class="service-block">
            <p class="service-block__title">What gets built</p>
            <ul class="service-list">
              {service.includes.map((item) => <li>{item}</li>)}
            </ul>
          </div>

          <div class="service-block">
            <p class="service-block__title">Examples</p>
            <div class="chip-list" role="list">
              {service.examples.map((item) => (
                <span class="chip" role="listitem">{item}</span>
              ))}
            </div>
          </div>

          <div class="service-footer">
            <p class="service-best-fit"><strong>Best fit buyer:</strong> {service.bestFor}</p>
            <div class="service-outcomes">
              {service.outcomes.map((outcome) => (
                <span class="service-outcome">{outcome}</span>
              ))}
            </div>
            <p class="service-pricing-note">{service.pricingNote}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="support-grid">
      <article class="support-card">
        <p class="service-block__title">Common supporting capabilities</p>
        <div class="chip-list" role="list">
          {supportingCapabilities.map((capability) => (
            <span class="chip chip--muted" role="listitem">{capability}</span>
          ))}
        </div>
      </article>

      <article class="support-card support-card--action">
        <p class="service-block__title">Need help choosing the right service line?</p>
        <p>
          Start with the workflow problem. If you can explain where the friction is, we can usually
          tell whether the right move is a system, a client-facing tool, or an automation layer.
        </p>
        <div class="support-card__actions">
          <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
          <Button href="/services" variant="dark">{ctaLabels.services}</Button>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-white);
  }

  .section-eyebrow,
  .service-card__eyebrow,
  .service-block__title,
  .service-meta__label {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-eyebrow,
  .service-card__eyebrow,
  .service-block__title {
    color: var(--color-primary);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-lg);
  }

  .service-card,
  .support-card {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .service-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  .service-card__top h3 {
    font-size: 1.6rem;
    line-height: 1.2;
    margin-bottom: var(--space-sm);
  }

  .service-card__problem,
  .service-best-fit,
  .service-pricing-note,
  .support-card p {
    line-height: 1.75;
    color: var(--color-text);
  }

  .service-meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-sm);
  }

  .service-meta__item {
    padding: 0.95rem 1rem;
    border-radius: var(--border-radius-sm);
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
    border: 1px solid rgba(42, 157, 143, 0.14);
  }

  .service-meta__label {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--color-primary);
  }

  .service-meta__item strong {
    display: block;
    color: var(--color-dark);
    line-height: 1.5;
    font-size: 0.98rem;
  }

  .service-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .service-list li {
    position: relative;
    padding-left: var(--space-md);
    line-height: 1.7;
    color: var(--color-text);
  }

  .service-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .chip-list,
  .service-outcomes,
  .support-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .chip,
  .service-outcome {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background-color: rgba(42, 157, 143, 0.08);
    color: var(--color-primary);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .chip--muted {
    background-color: var(--color-light);
    color: var(--color-dark);
  }

  .service-footer {
    margin-top: auto;
    display: grid;
    gap: var(--space-sm);
    padding-top: var(--space-md);
    border-top: 1px solid rgba(38, 70, 83, 0.08);
  }

  .service-pricing-note {
    margin-bottom: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .support-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.9fr);
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .support-card--action {
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.12), transparent 30%),
      linear-gradient(135deg, rgba(16, 32, 51, 0.98), rgba(23, 50, 74, 0.96));
    color: var(--color-white);
  }

  .support-card--action p {
    color: rgba(255, 255, 255, 0.92);
  }

  .support-card--action .service-block__title {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .support-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .services-grid,
    .service-meta {
      grid-template-columns: 1fr;
    }

    .support-card__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
