---
const services = [
  {
    title: 'Custom Business Systems',
    description:
      'Purpose-built software for teams that need clearer operations, better control, and fewer manual workarounds.',
    features: [
      'Internal platforms for staff and management',
      'Admin systems for records, approvals, and reporting',
      'Operations software for inventory, workflows, and day-to-day execution',
      'Role-based access, auditability, and maintainable architecture',
    ],
    bestFor: 'Businesses replacing spreadsheets, disconnected tools, or fragile manual processes.',
  },
  {
    title: 'Business Websites with Operational Value',
    description:
      'Websites designed to support the business, not just present it. The goal is clearer trust, better lead flow, and useful operational touchpoints.',
    features: [
      'Lead-focused pages with stronger inquiry paths',
      'Fast, mobile-friendly builds that are easy to maintain',
      'Booking, quote, contact, or intake flows where needed',
      'Credibility, performance, and structure aligned to business goals',
    ],
    bestFor: 'Companies that need their website to support sales, service delivery, or operational workflows.',
  },
  {
    title: 'Automation & Internal Tools',
    description:
      'Small but valuable systems that remove repetitive work, connect processes, and give teams faster access to the data they need.',
    features: [
      'Bots, utilities, and lightweight internal tooling',
      'Data workflows, imports, exports, and process automation',
      'Monitoring, notifications, and custom operational utilities',
      'Integrations that reduce manual handling across teams',
    ],
    bestFor: 'Teams that want to save time, reduce mistakes, and remove avoidable operational friction.',
  },
];

const supportingCapabilities = [
  'POS and inventory tooling',
  'Reporting dashboards',
  'API and backend development',
  'Role-based access control',
  'Data cleanup and migration utilities',
  'Security hardening and deployment support',
];
---

<section class="services section-padding" id="services">
  <div class="container">
    <div class="section-title">
      <h2>Core Services</h2>
      <p>Three focused offers for businesses that need dependable software support.</p>
      <p class="text-muted">
        I keep the homepage focused on the work I want to be hired for most often:
        operational systems, business websites with clear value, and practical automation.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <article class="service-card">
          <h3>{service.title}</h3>
          <p class="service-description">{service.description}</p>
          <ul class="service-features">
            {service.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <p class="service-best-for"><strong>Best fit:</strong> {service.bestFor}</p>
        </article>
      ))}
    </div>

    <div class="capabilities-panel">
      <p class="capabilities-label">Supporting capabilities</p>
      <div class="capabilities-list" role="list">
        {supportingCapabilities.map((capability) => (
          <span class="capability-chip" role="listitem">{capability}</span>
        ))}
      </div>
    </div>

    <div class="services-cta">
      <p class="cta-text">Need to figure out which service best matches your operations?</p>
      <a href="#contact" class="btn btn-primary">Start a Project Conversation</a>
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-white);
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .section-title h2 {
    position: relative;
    display: inline-block;
    margin-bottom: var(--space-sm);
  }

  .section-title h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background-color: var(--color-primary);
  }

  .section-title p {
    margin-bottom: var(--space-xs);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .service-card {
    background-color: var(--color-white);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow-md);
    transition: var(--transition);
    border: 1px solid var(--color-gray-light);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .service-card h3 {
    margin-bottom: var(--space-sm);
    color: var(--color-dark);
  }

  .service-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .service-features {
    list-style: none;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
    flex-grow: 1;
  }

  .service-features li {
    padding: var(--space-xs) 0;
    padding-left: var(--space-md);
    position: relative;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .service-features li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: bold;
  }

  .service-best-for {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-gray-light);
  }

  .capabilities-panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
    border: 1px solid rgba(42, 157, 143, 0.15);
  }

  .capabilities-label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .capabilities-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .capability-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    color: var(--color-dark);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .services-cta {
    text-align: center;
    margin-top: var(--space-xl);
  }

  .cta-text {
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
