---
import Button from '../ui/Button.astro';
import { servicePages } from '../../data/siteContent';
---

<section class="section-padding">
  <div class="container">
    <div class="section-title">
      <p class="eyebrow">Three Offers</p>
      <h2>Three ways I typically help</h2>
    </div>

    <div class="grid-3 offer-grid">
      {servicePages.map((service) => (
        <article class="surface-card offer-card">
          <h3>{service.title}</h3>

          <div class="offer-block">
            <h4>Problem</h4>
            <p>{service.problemStatement}</p>
          </div>

          <div class="offer-block">
            <h4>What I Build</h4>
            <p>{service.deliverables.slice(0, 5).join(', ')}.</p>
          </div>

          <div class="offer-block">
            <h4>Best Fit</h4>
            <p>{service.audienceSummary}</p>
          </div>

          <Button href={`/services/${service.slug}`} variant="dark">View Service Details</Button>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .offer-grid {
    align-items: start;
  }

  .offer-card {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    gap: 1rem;
    height: 100%;
  }

  .offer-card h3 {
    margin-bottom: 0;
  }

  .offer-block h4 {
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .offer-block p {
    margin-bottom: 0;
  }

  .offer-card :global(.btn) {
    align-self: end;
    margin-top: 0.35rem;
  }
</style>
