---
import { serviceOffers, supportingCapabilities } from '../../data/siteContent';
---

<section class="services section-padding" id="services">
  <div class="container">
    <div class="section-title">
      <h2>What You Can Hire Me For</h2>
      <p>Three focused offers for companies that need better operations, not just a nicer-looking website.</p>
      <p class="text-muted">
        This is intentionally not a list of everything I can code. It is a clear offer structure built around the problems I solve best.
      </p>
    </div>

    <div class="services-grid">
      {serviceOffers.map((service) => (
        <article class="service-card">
          <h3>{service.title}</h3>
          <p class="service-description">{service.description}</p>
          <ul class="service-features">
            {service.includes.map((feature) => <li>{feature}</li>)}
          </ul>
          <p class="service-best-for"><strong>Best fit:</strong> {service.bestFor}</p>
        </article>
      ))}
    </div>

    <div class="capabilities-panel">
      <p class="capabilities-label">Supporting capabilities</p>
      <div class="capabilities-list" role="list">
        {supportingCapabilities.map((capability) => (
          <span class="capability-chip" role="listitem">{capability}</span>
        ))}
      </div>
    </div>

    <div class="services-cta">
      <p class="cta-text">Need help deciding which offer best matches the bottleneck in your workflow?</p>
      <div class="services-cta__actions">
        <a href="/services" class="btn btn-dark">Explore the Services</a>
        <a href="/contact" class="btn btn-primary">Discuss Your Workflow</a>
      </div>
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-white);
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .section-title h2 {
    position: relative;
    display: inline-block;
    margin-bottom: var(--space-sm);
  }

  .section-title h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background-color: var(--color-primary);
  }

  .section-title p {
    margin-bottom: var(--space-xs);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .service-card {
    background-color: var(--color-white);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow-md);
    transition: var(--transition);
    border: 1px solid var(--color-gray-light);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .service-card h3 {
    margin-bottom: var(--space-sm);
    color: var(--color-dark);
  }

  .service-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .service-features {
    list-style: none;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
    flex-grow: 1;
  }

  .service-features li {
    padding: var(--space-xs) 0;
    padding-left: var(--space-md);
    position: relative;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .service-features li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: bold;
  }

  .service-best-for {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-gray-light);
  }

  .capabilities-panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.08), rgba(38, 70, 83, 0.04));
    border: 1px solid rgba(42, 157, 143, 0.15);
  }

  .capabilities-label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .capabilities-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .capability-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    color: var(--color-dark);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .services-cta {
    text-align: center;
    margin-top: var(--space-xl);
  }

  .services-cta__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .cta-text {
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
