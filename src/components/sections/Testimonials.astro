---
interface Testimonial {
  text: string;
  author: string;
  role: string;
  industry: string;
  location?: string;
  date?: string;
}

const testimonials: Testimonial[] = [
  {
    text: "The travel agency website transformed how we handle customer inquiries. We now receive more qualified leads and the booking process is much smoother. The mobile-friendly design means customers can easily reach us from anywhere.",
    author: "Travel Agency Client",
    role: "Owner",
    industry: "Travel & Tourism",
    location: "PH",
  },
  {
    text: "The church management system has streamlined our operations significantly. We can now track members, manage events, and communicate announcements all in one place. It's saved us hours of administrative work each week.",
    author: "Religious Organization Client",
    role: "Administrator",
    industry: "Religious Organization",
    location: "PH",
  },
  {
    text: "Professional service and excellent communication throughout the project. Our business website was delivered on time and looks exactly as we envisioned. The clean design and fast loading speed have improved our online presence.",
    author: "Café Owner",
    role: "Business Owner",
    industry: "Food & Beverage",
    location: "KH",
  }
];
---

<section class="testimonials section-padding" id="testimonials">
  <div class="container">
    <div class="section-title">
      <h2>Client Testimonials</h2>
      <p>What businesses say about working with me.</p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((testimonial) => (
        <article class="testimonial-card">
          <blockquote class="testimonial-text">
            "{testimonial.text}"
          </blockquote>
          <footer class="testimonial-author">
            <cite>— {testimonial.author}</cite>
            <p class="testimonial-role">{testimonial.role} · {testimonial.industry}</p>
            {testimonial.location && testimonial.date && (
              <p class="testimonial-meta">{testimonial.location} · {testimonial.date}</p>
            )}
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: var(--color-light);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .testimonial-card {
    background: var(--color-white);
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-md);
    border-left: 4px solid var(--color-primary);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }

  .testimonial-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-left-width: 5px;
  }

  .testimonial-text {
    font-style: italic;
    margin-bottom: var(--space-md);
    color: var(--color-text);
    font-size: clamp(1rem, 2vw, 1.05rem);
    line-height: 1.7;
    position: relative;
    flex-grow: 1;
  }

  .testimonial-text::before {
    content: '"';
    font-size: 3rem;
    color: var(--color-primary);
    opacity: 0.2;
    position: absolute;
    left: -10px;
    top: -10px;
    line-height: 1;
  }

  .testimonial-author {
    text-align: right;
    margin-top: auto;
  }

  .testimonial-author cite {
    font-weight: 600;
    color: var(--color-primary);
    font-style: normal;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .testimonial-role {
    font-size: 0.9rem;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: var(--space-xs);
    margin-top: 0;
  }

  .testimonial-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    margin-bottom: 0;
  }
</style>
