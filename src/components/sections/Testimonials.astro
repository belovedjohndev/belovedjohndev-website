---
import { testimonials } from '../../data/siteContent';
---

<section class="testimonials section-padding" id="testimonials">
  <div class="container">
    <div class="section-title">
      <p class="section-eyebrow">Client feedback</p>
      <h2>Trust signals from clients who needed business results, not just code delivery</h2>
      <p>Some names are generalized to respect client privacy, but the feedback is kept specific to the kind of value the work created.</p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((testimonial) => (
        <article class="testimonial-card">
          <div class="testimonial-card__top">
            <p class="testimonial-headline">{testimonial.headline}</p>
            <p class="testimonial-context">{testimonial.context}</p>
          </div>

          <div class="testimonial-proof" role="list" aria-label="Testimonial proof points">
            {testimonial.proof.map((point) => (
              <span class="testimonial-proof__chip" role="listitem">{point}</span>
            ))}
          </div>

          <blockquote class="testimonial-text">{testimonial.quote}</blockquote>

          <footer class="testimonial-author">
            <cite>{testimonial.author}</cite>
            <p class="testimonial-role">{testimonial.role} | {testimonial.company}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: var(--color-light);
  }

  .section-eyebrow {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .testimonial-card {
    display: grid;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .testimonial-headline {
    margin-bottom: 0.4rem;
    font-size: 1.1rem;
    line-height: 1.35;
    font-weight: 700;
    color: var(--color-dark);
  }

  .testimonial-context,
  .testimonial-text,
  .testimonial-role {
    color: var(--color-text);
    line-height: 1.75;
  }

  .testimonial-context,
  .testimonial-role {
    margin-bottom: 0;
  }

  .testimonial-proof {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .testimonial-proof__chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background-color: rgba(42, 157, 143, 0.08);
    color: var(--color-primary);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .testimonial-text {
    margin: 0;
    font-size: 1rem;
    font-style: italic;
  }

  .testimonial-author cite {
    display: block;
    margin-bottom: 0.2rem;
    font-style: normal;
    font-weight: 700;
    color: var(--color-dark);
  }
</style>
