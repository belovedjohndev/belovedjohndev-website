---
interface Testimonial {
  text: string;
  author: string;
  location?: string;
  date?: string;
}

const testimonials: Testimonial[] = [
  {
    text: "Beloved John created a beautiful website for my travel agency. He was professional, responsive, and delivered exactly what we needed. Highly recommended!",
    author: "Travel Agency Client",
    location: "PH",
    date: "March 21, 2024"
  },
  {
    text: "The website for our organization is perfect - clean, easy to navigate, and works perfectly on mobile. Beloved John understood exactly what we wanted.",
    author: "Religious Organization Client",
    location: "PH",
    date: "May 12, 2025"
  },
  {
    text: "Affordable pricing and excellent communication. My business website was ready in just 4 days and looks professional. Will definitely work with him again!",
    author: "Café Owner",
    location: "KH",
    date: "December 11, 2024"
  }
];
---

<section class="testimonials section-padding" id="testimonials">
  <div class="container">
    <div class="section-title">
      <h2>Client Testimonials</h2>
      <p>What clients say about working with me.</p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((testimonial) => (
        <article class="testimonial-card">
          <blockquote class="testimonial-text">
            "{testimonial.text}"
          </blockquote>
          <footer class="testimonial-author">
            <cite>— {testimonial.author}</cite>
            {testimonial.location && testimonial.date && (
              <p class="testimonial-meta">{testimonial.location} · {testimonial.date}</p>
            )}
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: var(--color-white);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .testimonial-card {
    background: var(--color-white);
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-md);
    border-left: 4px solid var(--color-primary);
    transition: var(--transition);
  }

  .testimonial-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .testimonial-text {
    font-style: italic;
    margin-bottom: var(--space-md);
    color: var(--color-text);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .testimonial-author {
    text-align: right;
  }

  .testimonial-author cite {
    font-weight: 600;
    color: var(--color-primary);
    font-style: normal;
  }

  .testimonial-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    margin-bottom: 0;
  }
</style>
