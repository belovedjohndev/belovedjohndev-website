---
import { operationalSymptoms } from '../../data/siteContent';
---

<section class="section-padding">
  <div class="container">
    <div class="section-title pain-title">
      <p class="eyebrow">Buyer Pain</p>
      <h2>The business is growing. The back-office has not kept up.</h2>
      <p>
        Most clients reach out when revenue is moving in the right direction, but the operational layer is still held
        together by workarounds.
      </p>
    </div>

    <div class="grid-2 pain-grid">
      {operationalSymptoms.map((item) => (
        <article class="simple-card pain-card">
          <p>{item}</p>
        </article>
      ))}
    </div>

    <p class="pain-close">
      The problem is usually not the website. It is the system behind the business.
    </p>
  </div>
</section>

<style>
  .pain-title {
    max-width: 780px;
  }

  .pain-grid {
    align-items: stretch;
  }

  .pain-card {
    border-left: 4px solid var(--color-primary);
  }

  .pain-card p,
  .pain-close {
    margin-bottom: 0;
  }

  .pain-close {
    margin-top: var(--space-lg);
    color: var(--color-text-muted);
    font-weight: 700;
  }
</style>
