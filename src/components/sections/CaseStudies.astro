---
import Button from '../ui/Button.astro';
import { caseStudies, featuredCaseStudySlugs } from '../../data/siteContent';
import { getWebpVariant, hasWebpVariant } from '../../utils/images';

const featuredStudySet = new Set(featuredCaseStudySlugs);
const featuredStudies = caseStudies.filter((study) =>
  featuredStudySet.has(study.slug as (typeof featuredCaseStudySlugs)[number])
);
---

<section class="section-padding proof-band">
  <div class="container">
    <div class="section-title">
      <p class="eyebrow">Featured Case Studies</p>
      <h2>Projects built around operational bottlenecks.</h2>
    </div>

    <div class="study-grid">
      {featuredStudies.map((study) => (
        <article class="surface-card study-card">
          <div class="study-card__media">
            <picture>
              {hasWebpVariant(study.image) && <source srcset={getWebpVariant(study.image)} type="image/webp" />}
              <img src={study.image} alt={study.alt} width="900" height="600" loading="lazy" decoding="async" />
            </picture>
          </div>
          <div class="study-card__body">
            <p class="study-card__tag">{study.homepageLabel ?? study.serviceLine}</p>
            <h3>{study.title}</h3>

            <p class="study-line"><strong>Problem:</strong> {study.problemOneLiner}</p>
            <p class="study-line"><strong>Outcome:</strong> {study.outcomeOneLiner}</p>

            <div class="study-actions">
              <Button href={`/case-studies/${study.slug}`} variant="dark">Read Case Study</Button>
              {study.referenceExternal && study.referenceHref && study.referenceLabel.toLowerCase().includes('demo') && (
                <Button href={study.referenceHref} variant="primary" target="_blank" rel="noopener">
                  View Live Demo
                </Button>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="study-more">
      <Button href="/case-studies" variant="dark">View All Case Studies</Button>
    </div>
  </div>
</section>

<style>
  .proof-band {
    background: rgba(255, 255, 255, 0.45);
  }

  .study-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .study-card {
    overflow: hidden;
    padding: 0;
  }

  .study-card__media {
    position: relative;
    display: grid;
    place-items: center;
    min-height: clamp(13rem, 20vw, 18rem);
    padding: clamp(1rem, 2vw, 1.35rem);
    background: rgba(244, 246, 247, 0.96);
    border-bottom: 1px solid rgba(16, 32, 51, 0.08);
  }

  .study-card picture {
    width: 100%;
  }

  .study-card img {
    width: 100%;
    max-height: clamp(11rem, 18vw, 16rem);
    object-fit: contain;
    object-position: center top;
    border-radius: calc(var(--border-radius) - 0.35rem);
    box-shadow: 0 4px 14px rgba(16, 32, 51, 0.06);
  }

  .study-card__body {
    display: grid;
    gap: 0.9rem;
    padding: var(--space-lg);
  }

  .study-card__tag {
    width: fit-content;
    margin-bottom: 0;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .study-line {
    margin-bottom: 0;
    padding: 0.85rem;
    border-radius: var(--border-radius-sm);
    background: rgba(244, 246, 247, 0.82);
    border: 1px solid rgba(16, 32, 51, 0.08);
    line-height: 1.62;
  }

  .study-line strong {
    color: var(--color-dark);
  }

  .study-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    align-items: stretch;
  }

  .study-actions :global(.btn) {
    flex: 1 1 220px;
  }

  .study-more {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 1100px) {
    .study-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .study-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
