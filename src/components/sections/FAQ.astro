---
import JsonLd from '../JsonLd.astro';
import { faqItems } from '../../data/siteContent';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="section-padding">
  <JsonLd data={faqSchema} />

  <div class="container">
    <div class="section-title">
      <p class="eyebrow">Sales FAQ</p>
      <h2>Common questions before starting</h2>
    </div>

    <div class="faq-grid">
      {faqItems.map((faq) => (
        <article class="surface-card faq-card">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .faq-card p {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
