---
interface FAQItem {
  question: string;
  answer: string;
}

const faqs: FAQItem[] = [
  {
    question: "How long does it take to build a custom system?",
    answer: "Timeline depends on complexity. Simple systems (invoice generators, basic automation) take 1-2 weeks. Medium systems (POS, inventory management) take 3-6 weeks. Complex systems (full management platforms) take 6-12 weeks. I'll provide a detailed timeline after discussing your requirements."
  },
  {
    question: "Do you provide hosting and server setup?",
    answer: "Yes, I can guide you through hosting options suitable for your system, or I can manage the hosting setup for you. We'll discuss the best approach based on your needs and budget."
  },
  {
    question: "Can I request changes during development?",
    answer: "Yes. I include revision rounds during development to ensure the system meets your expectations. We'll have regular check-ins to review progress and make adjustments as needed."
  },
  {
    question: "What if my business needs change after launch?",
    answer: "I provide 30 days of free support after launch. For ongoing changes and new features, we can discuss a maintenance plan or project-based updates to keep your system aligned with your business growth."
  },
  {
    question: "How does payment work?",
    answer: "Payment terms vary by project size. Small projects: 50% upfront / 50% on completion. Medium to large projects: 40% upfront / 40% at milestone / 20% on completion. We'll agree on terms before starting."
  },
  {
    question: "Do you provide training for my team?",
    answer: "Yes. I provide documentation and training sessions to ensure your team can use the system effectively. Training is included in the project scope."
  },
  {
    question: "Can the system work offline?",
    answer: "Depending on your needs, I can build systems with offline capabilities. This is especially useful for POS systems and inventory management in areas with unreliable internet. We'll discuss this during planning."
  },
  {
    question: "Is my business data secure?",
    answer: "Absolutely. Security is a priority. I implement industry-standard security practices including data encryption, secure authentication, regular backups, and follow ethical development principles to protect your business information."
  }
];
---

<section class="faq section-padding" id="faq">
  <div class="container">
    <div class="section-title">
      <h2>Frequently Asked Questions</h2>
      <p>Common questions about digital solutions and systems.</p>
    </div>

    <div class="faq-grid">
      {faqs.map((faq) => (
        <article class="faq-card">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    background-color: var(--color-light);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .faq-card {
    background-color: var(--color-white);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow-md);
    transition: var(--transition);
    border-left: 4px solid transparent;
  }

  .faq-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-left-color: var(--color-primary);
  }

  .faq-card h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
    color: var(--color-dark);
  }

  .faq-card p {
    color: var(--color-text);
    margin-bottom: 0;
    line-height: 1.7;
  }
</style>
