---
interface FAQItem {
  question: string;
  answer: string;
}

const faqs: FAQItem[] = [
  {
    question: "How long does it take to build a custom system?",
    answer:
      "It depends on complexity. Simple tools (invoice generators, basic automation) usually take 1–2 weeks. Medium systems (POS, inventory management) take around 3–6 weeks. Larger platforms take longer. I provide a clear timeline after understanding your requirements."
  },
  {
    question: "Do you help with hosting and server setup?",
    answer:
      "Yes. I can recommend reliable hosting options or handle the setup for you. The choice depends on your budget, traffic, and how critical the system is to your business."
  },
  {
    question: "Can I request changes during development?",
    answer:
      "Absolutely. We review progress regularly, and I include revision rounds so the system matches your real workflow, not just initial assumptions."
  },
  {
    question: "What happens after the system is launched?",
    answer:
      "I provide 30 days of free post-launch support. If you need ongoing improvements or new features later, we can plan updates as your business grows."
  },
  {
    question: "How does payment work?",
    answer:
      "For small projects: 50% upfront and 50% on completion. For larger projects: milestone-based payments. All terms are agreed clearly before work starts."
  },
  {
    question: "Can my system work without internet?",
    answer:
      "Yes, depending on the use case. Some systems, especially POS and inventory tools, can be designed to work offline and sync data when the internet is available."
  },
  {
    question: "Is my business data secure?",
    answer:
      "Yes. Security is planned from the start. I use secure authentication, proper access control, encrypted connections, and backups. Protection is matched to how sensitive your data is — no unnecessary complexity, no shortcuts."
  }
];
---

<section class="faq section-padding" id="faq">
  <div class="container">
    <div class="section-title">
      <h2>Frequently Asked Questions</h2>
      <p>Common questions about digital solutions and systems.</p>
    </div>

    <div class="faq-grid">
      {faqs.map((faq) => (
        <article class="faq-card">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    background-color: var(--color-light);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .faq-card {
    background-color: var(--color-white);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow-md);
    transition: var(--transition);
    border-left: 4px solid transparent;
  }

  .faq-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-left-color: var(--color-primary);
  }

  .faq-card h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
    color: var(--color-dark);
  }

  .faq-card p {
    color: var(--color-text);
    margin-bottom: 0;
    line-height: 1.7;
  }
</style>
