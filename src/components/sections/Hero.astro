---
import Button from '../ui/Button.astro';
import { ctaLabels, heroProofPoints, sitePositioning } from '../../data/siteContent';
---

<section class="page-hero home-hero">
  <div class="container page-hero__content">
    <p class="eyebrow">{sitePositioning.eyebrow}</p>
    <h1>{sitePositioning.title}</h1>
    <p class="page-hero__lead">{sitePositioning.lead}</p>

    <div class="hero-actions">
      <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
      <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
    </div>

    <div class="proof-row" role="list" aria-label="Hero proof points">
      {heroProofPoints.map((item) => (
        <span class="proof-pill" role="listitem">{item}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .home-hero {
    padding: 8.5rem 0 5.75rem;
  }

  .home-hero .page-hero__content {
    max-width: 940px;
  }

  .proof-row {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: calc(var(--space-sm) + 0.25rem);
    max-width: 58rem;
  }

  .proof-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.86rem;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .home-hero {
      padding: 7rem 0 4.25rem;
    }
  }
</style>
