---
import Button from '../ui/Button.astro';
import { ctaLabels, heroProofPoints, primaryCtaHref, sitePositioning } from '../../data/siteContent';
---

<section class="page-hero home-hero">
  <div class="container page-hero__content">
    <p class="eyebrow">{sitePositioning.eyebrow}</p>
    <h1>{sitePositioning.title}</h1>
    <p class="page-hero__lead">{sitePositioning.lead}</p>

    <div class="hero-actions">
      <Button href={primaryCtaHref} variant="primary">{ctaLabels.primary}</Button>
      <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
    </div>

    <p class="proof-line" aria-label="Hero proof points">
      {heroProofPoints.map((item, i) => (
        <span>{item}{i < heroProofPoints.length - 1 && <span class="proof-sep" aria-hidden="true">·</span>}</span>
      ))}
    </p>
  </div>
</section>

<style>
  .home-hero {
    position: relative;
    overflow: hidden;
    padding: 7.8rem 0 4.85rem;
    background:
      linear-gradient(135deg, rgba(7, 18, 31, 0.9), rgba(12, 34, 48, 0.8)),
      image-set(
        url('/assets/images/hero-bg.webp') type('image/webp'),
        url('/assets/images/hero-bg.png') type('image/png')
      )
        center / cover no-repeat;
  }

  .home-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(7, 18, 31, 0.08), rgba(7, 18, 31, 0.28));
    pointer-events: none;
  }

  .home-hero .page-hero__content {
    position: relative;
    z-index: 1;
    max-width: 940px;
  }

  .proof-line {
    display: block;
    margin-top: calc(var(--space-sm) + 0.25rem);
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    max-width: 58rem;
    line-height: 1.8;
  }

  .proof-sep {
    margin: 0 0.35rem;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .home-hero {
      padding: 6.6rem 0 3.55rem;
    }
  }
</style>
