---
import { homePainPoints } from '../../data/siteContent';
---

<section class="hero" id="top">
  <div class="container hero-content">
    <p class="hero-eyebrow">Independent business systems developer</p>
    <h1>
      I build custom business systems that replace spreadsheets, manual workflows, and disconnected tools.
    </h1>

    <p class="hero-subtitle">
      For service businesses, agencies, and growing teams, I design and build internal
      tools, client portals, estimator flows, and automation that make operations easier
      to run and easier to scale.
    </p>

    <p class="hero-location">
      Best fit for companies that have outgrown spreadsheets, patched-together tools,
      and manual handoffs but do not want bloated agency overhead.
    </p>

    <div class="hero-buttons">
      <a href="/contact" class="btn btn-primary">
        Discuss Your Workflow
      </a>

      <a href="/case-studies" class="btn btn-secondary">
        Review Case Studies
      </a>

      <a href="/services" class="btn btn-secondary btn-ghost">
        See What I Build
      </a>
    </div>

    <div class="hero-problems">
      <p class="hero-offer__label">Common reasons clients reach out</p>
      <p class="hero-problems__intro">
        The pattern is usually the same: the business is growing, but the workflow is still being held together manually.
      </p>
      <div class="hero-problem-list" role="list" aria-label="Operational pain points">
        {homePainPoints.slice(0, 4).map((painPoint) => (
          <span class="hero-problem" role="listitem">{painPoint}</span>
        ))}
      </div>
    </div>

    <div class="hero-focuses" role="list" aria-label="Core focus areas">
      <span class="hero-focus" role="listitem">Custom business systems</span>
      <span class="hero-focus" role="listitem">Client portals and estimator tools</span>
      <span class="hero-focus" role="listitem">Automation and integrations</span>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    color: var(--color-white);
    padding: 6.75rem 0 4.75rem;
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.14), transparent 24%),
      radial-gradient(circle at left center, rgba(22, 138, 122, 0.18), transparent 28%),
      linear-gradient(135deg, rgba(10, 22, 35, 0.92), rgba(16, 50, 66, 0.9)),
      url('/assets/images/hero-bg.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      rgba(42, 157, 143, 0.15),
      transparent 60%
    );
    pointer-events: none;
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }

    50% {
      opacity: 0.85;
    }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 840px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero h1 {
    margin-bottom: var(--space-md);
    color: var(--color-white);
    line-height: 1.2;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.28rem);
    opacity: 0.95;
    margin-bottom: var(--space-sm);
    line-height: 1.8;
    max-width: 760px;
  }

  .hero-location {
    font-size: 1rem;
    opacity: 0.85;
    margin-bottom: var(--space-lg);
    line-height: 1.8;
    max-width: 640px;
  }

  .hero-buttons {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .hero-buttons .btn {
    min-width: 180px;
  }

  .btn-ghost {
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--color-white);
  }

  .btn-ghost:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .hero-problems {
    margin-top: var(--space-lg);
    padding: 1.35rem;
    max-width: 720px;
    border-radius: var(--border-radius);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(16px);
    box-shadow: var(--shadow-lg);
  }

  .hero-offer__label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .hero-problem-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero-problems__intro {
    margin-bottom: var(--space-sm);
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.7;
  }

  .hero-problem {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.9rem;
  }

  .hero-focuses {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .hero-focus {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--color-white);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 5rem 0 3rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
    }

    .hero-buttons .btn {
      width: 100%;
    }
  }
</style>
