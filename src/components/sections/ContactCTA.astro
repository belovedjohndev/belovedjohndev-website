---
import { contactLinks } from '../../data/siteContent';
---

<section class="contact-cta section-padding" id="contact">
  <div class="container">
    <div class="section-title">
      <h2>Tell Me Where the Workflow Is Breaking</h2>
      <p>Tell me what the business needs to do better, faster, or with less manual handling.</p>
      <p class="text-muted">
        If you need a custom system, a client portal, an estimator tool, or automation
        that removes repetitive work, we can start with a direct project conversation.
      </p>
    </div>

    <div class="contact-methods">
      <a
        href={contactLinks.whatsapp}
        class="contact-method"
        target="_blank"
        rel="noopener"
        aria-label="Contact via WhatsApp"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        <span>Start on WhatsApp</span>
      </a>

      <a
        href={contactLinks.telegram}
        class="contact-method"
        target="_blank"
        rel="noopener"
        aria-label="Contact via Telegram"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        <span>Message on Telegram</span>
      </a>

      <a href={contactLinks.mailto} class="contact-method contact-method--page">
        <span>Email Support</span>
      </a>

      <a href="/contact" class="contact-method contact-method--page">
        <span>Open Contact Page</span>
      </a>
    </div>

    <p class="contact-note text-center">
      I typically respond within 24 hours with next steps, fit feedback, or follow-up questions. You can also reach me at {contactLinks.email}.
    </p>
  </div>
</section>

<style>
  .contact-cta {
    background: linear-gradient(135deg, var(--color-dark) 0%, var(--color-primary) 100%);
    color: var(--color-white);
  }

  .contact-cta .section-title h2 {
    color: var(--color-white);
  }

  .contact-cta .section-title h2::after {
    background-color: var(--color-accent);
  }

  .contact-cta .section-title p {
    color: rgba(255, 255, 255, 0.95);
  }

  .contact-cta .text-muted {
    color: rgba(255, 255, 255, 0.85);
  }

  .contact-methods {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    margin: var(--space-xl) 0;
    flex-wrap: wrap;
  }

  .contact-method {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    background-color: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--border-radius);
    color: var(--color-white);
    font-weight: 500;
    transition: var(--transition);
    font-size: 1.05rem;
  }

  .contact-method:hover {
    background-color: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .contact-method:active {
    transform: translateY(-1px);
  }

  .contact-method:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 2px;
  }

  .contact-method svg {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .contact-method--page {
    min-width: 220px;
    justify-content: center;
  }

  .contact-note {
    margin-top: var(--space-lg);
    color: rgba(255, 255, 255, 0.9);
  }
</style>
