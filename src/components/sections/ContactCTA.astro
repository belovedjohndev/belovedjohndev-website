---
import Button from '../ui/Button.astro';
import { contactLinks, ctaLabels, nextStepTimeline } from '../../data/siteContent';
---

<section class="contact-cta section-padding" id="contact">
  <div class="container contact-cta__grid">
    <div class="contact-cta__copy">
      <p class="section-eyebrow">Start here</p>
      <h2>Start a project conversation with the workflow problem, not a polished spec.</h2>
      <p class="contact-cta__lead">
        If the business is dealing with spreadsheet sprawl, manual handoffs, weak lead intake, or disconnected tools,
        that is enough context to begin. I can help shape the first useful scope from there.
      </p>

      <div class="contact-cta__actions">
        <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
        <Button href="/case-studies" variant="secondary">{ctaLabels.secondary}</Button>
      </div>

      <div class="contact-cta__channels">
        <a href={contactLinks.whatsapp} target="_blank" rel="noopener">Start on WhatsApp</a>
        <a href={contactLinks.telegram} target="_blank" rel="noopener">Message on Telegram</a>
        <a href={contactLinks.mailto}>Email {contactLinks.email}</a>
      </div>
    </div>

    <div class="contact-cta__panel">
      <p class="panel-label">What happens next</p>
      <div class="timeline-list">
        {nextStepTimeline.map((item) => (
          <article class="timeline-item">
            <p class="timeline-item__step">{item.step}</p>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="contact-cta__note">
        The goal of the first reply is clarity: fit feedback, scoping direction, and whether the work should be handled as a system,
        client-facing tool, or automation layer.
      </p>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    background:
      radial-gradient(circle at top right, rgba(240, 188, 116, 0.12), transparent 28%),
      linear-gradient(135deg, var(--color-dark) 0%, var(--color-primary) 100%);
    color: var(--color-white);
  }

  .contact-cta__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
    gap: var(--space-lg);
    align-items: start;
  }

  .section-eyebrow,
  .panel-label,
  .timeline-item__step {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-eyebrow,
  .panel-label {
    color: var(--color-accent);
  }

  .contact-cta h2,
  .timeline-item h3 {
    color: var(--color-white);
  }

  .contact-cta__lead,
  .timeline-item p,
  .contact-cta__note {
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.92);
  }

  .contact-cta__actions,
  .contact-cta__channels {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .contact-cta__actions {
    margin-top: var(--space-lg);
  }

  .contact-cta__channels {
    margin-top: var(--space-md);
  }

  .contact-cta__channels a {
    color: var(--color-white);
    font-weight: 600;
  }

  .contact-cta__panel {
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background: rgba(8, 18, 27, 0.34);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow-lg);
  }

  .timeline-list {
    display: grid;
    gap: var(--space-md);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm);
    align-items: start;
  }

  .timeline-item__step {
    margin: 0;
    color: var(--color-accent);
  }

  .timeline-item h3 {
    font-size: 1.02rem;
    margin-bottom: 0.35rem;
  }

  .timeline-item p,
  .contact-cta__note {
    margin-bottom: 0;
  }

  .contact-cta__note {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 900px) {
    .contact-cta__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .contact-cta__actions,
    .contact-cta__channels {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
