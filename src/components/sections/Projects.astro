---
import Button from '../ui/Button.astro';
import { caseStudies, ctaLabels } from '../../data/siteContent';
---

<section class="projects section-padding" id="projects">
  <div class="container">
    <div class="section-title">
      <p class="section-eyebrow">Proof</p>
      <h2>Featured case studies built around real workflow problems</h2>
      <p>
        These examples are framed the way serious buyers evaluate projects: what was broken,
        what was built, and what became easier or more reliable afterward.
      </p>
    </div>

    <div class="projects-grid">
      {caseStudies.map((project) => (
        <article class="project-card">
          <div class="project-media">
            <img
              src={project.image}
              alt={project.alt}
              width="600"
              height="400"
              loading="lazy"
              class="project-image"
            />
          </div>

          <div class="project-content">
            <div class="project-header">
              <div>
                <p class="project-category">{project.category}</p>
                <h3>{project.title}</h3>
              </div>
              <p class="project-audience">{project.audience}</p>
            </div>

            <p class="project-summary">{project.summary}</p>

            <div class="project-proof-grid">
              {project.proofPoints.slice(0, 3).map((point) => (
                <article class="project-proof-card">
                  <p class="project-proof-card__value">{point.value}</p>
                  <p class="project-proof-card__label">{point.label}</p>
                </article>
              ))}
            </div>

            <div class="project-columns">
              <div class="project-section">
                <p class="project-section__label">Problem</p>
                <p>{project.problem}</p>
              </div>

              <div class="project-section">
                <p class="project-section__label">What was built</p>
                <ul class="check-list">
                  {project.features.slice(0, 4).map((highlight) => <li>{highlight}</li>)}
                </ul>
              </div>
            </div>

            <div class="project-footer">
              <div class="project-tech" role="list" aria-label="Technology used">
                {project.stack.map((tag) => (
                  <span class="tech-tag" role="listitem">{tag}</span>
                ))}
              </div>

              <div class="project-links">
                <a href={`/case-studies/${project.slug}`}>Read the case study</a>
                {project.referenceHref ? (
                  <a
                    href={project.referenceHref}
                    target={project.referenceExternal === false ? undefined : '_blank'}
                    rel={project.referenceExternal === false ? undefined : 'noopener nofollow'}
                  >
                    {project.referenceText}
                  </a>
                ) : (
                  <span class="project-reference">{project.referenceText}</span>
                )}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="projects-footer">
      <Button href="/case-studies" variant="dark">{ctaLabels.secondary}</Button>
      <Button href="/contact" variant="primary">{ctaLabels.primary}</Button>
    </div>
  </div>
</section>

<style>
  .projects {
    background-color: var(--color-white);
  }

  .section-eyebrow,
  .project-category,
  .project-section__label {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-eyebrow,
  .project-category,
  .project-section__label {
    color: var(--color-primary);
  }

  .projects-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .project-card {
    display: grid;
    grid-template-columns: minmax(280px, 0.92fr) minmax(0, 1.15fr);
    gap: var(--space-lg);
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    border: 1px solid rgba(38, 70, 83, 0.08);
    box-shadow: var(--shadow-md);
  }

  .project-media {
    background: linear-gradient(135deg, rgba(38, 70, 83, 0.95), rgba(42, 157, 143, 0.72));
    border-radius: var(--border-radius);
    overflow: hidden;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-content {
    display: grid;
    gap: var(--space-md);
  }

  .project-header {
    display: grid;
    gap: var(--space-sm);
  }

  .project-audience,
  .project-summary,
  .project-section p,
  .project-reference {
    line-height: 1.75;
    color: var(--color-text);
  }

  .project-audience {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  .project-proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-sm);
  }

  .project-proof-card {
    padding: var(--space-sm);
    border-radius: var(--border-radius-sm);
    background-color: var(--color-light);
    border: 1px solid rgba(42, 157, 143, 0.12);
  }

  .project-proof-card__value {
    margin-bottom: 0.25rem;
    font-size: 1rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--color-dark);
  }

  .project-proof-card__label {
    margin-bottom: 0;
    font-size: 0.82rem;
    color: var(--color-text);
  }

  .project-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
  }

  .check-list {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-md);
    line-height: 1.7;
    color: var(--color-text);
  }

  .check-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .project-footer,
  .project-tech,
  .project-links,
  .projects-footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .project-footer {
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(38, 70, 83, 0.08);
  }

  .tech-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background-color: rgba(42, 157, 143, 0.08);
    color: var(--color-primary);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .project-links a {
    font-weight: 600;
  }

  .projects-footer {
    justify-content: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 960px) {
    .project-card,
    .project-columns,
    .project-proof-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .project-footer,
    .projects-footer {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
