---
import { caseStudies } from '../../data/siteContent';
---

<section class="projects section-padding" id="projects">
  <div class="container">
    <div class="section-title">
      <h2>Featured Case Studies</h2>
      <p>Examples of systems, portals, and operational software shaped around real business problems.</p>
    </div>

    <div class="projects-grid">
      {caseStudies.map((project) => (
        <article class="project-card">
          <div class="project-image-wrapper">
            <div class="project-media">
              {project.image && (
                <img
                  src={project.image}
                  alt={project.alt}
                  width="600"
                  height="400"
                  loading="lazy"
                  class="project-image"
                />
              )}
            </div>
          </div>
          <div class="project-content">
            <div class="project-meta" aria-label="Project type and technologies">
              {project.category} | {project.stack.join(', ')}
            </div>
            <h3>{project.title}</h3>
            <p class="project-summary">{project.summary}</p>

            <div class="project-highlights" role="list">
              {project.features.slice(0, 3).map((highlight) => (
                <span class="project-highlight" role="listitem">{highlight}</span>
              ))}
            </div>

            <div class="project-proof-grid">
              {project.proofPoints.slice(0, 2).map((point) => (
                <article class="project-proof-card">
                  <p class="project-proof-card__value">{point.value}</p>
                  <p class="project-proof-card__label">{point.label}</p>
                </article>
              ))}
            </div>

            <div class="project-section">
              <h4>Problem</h4>
              <p class="project-description">{project.problem}</p>
            </div>

            <div class="project-section">
              <h4>Approach</h4>
              <p>{project.approach}</p>
            </div>

            <div class="project-section">
              <h4>Solution</h4>
              <p class="project-description">{project.solution}</p>
            </div>

            <div class="project-tech" role="list">
              {project.stack.map((tag) => (
                <span class="tech-tag" role="listitem">{tag}</span>
              ))}
            </div>

            <div class="project-section">
              <h4>Outcome</h4>
              <p class="project-result">{project.outcome}</p>
            </div>

            <p class="project-reference">
              <a href={`/case-studies/${project.slug}`}>Read the case study</a>
              {' '}|{' '}
              <strong>{project.referenceLabel}:</strong>{' '}
              {project.referenceHref ? (
                <a
                  href={project.referenceHref}
                  target={project.referenceExternal === false ? undefined : '_blank'}
                  rel={project.referenceExternal === false ? undefined : 'noopener nofollow'}
                >
                  {project.referenceText}
                </a>
              ) : (
                <span>{project.referenceText}</span>
              )}
            </p>
          </div>
        </article>
      ))}
    </div>

    <div class="projects-footer">
      <a href="/case-studies" class="btn btn-dark">View All Case Studies</a>
    </div>
  </div>
</section>

<style>
  .projects {
    background-color: var(--color-light);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--space-xl);
  }

  .project-card {
    background-color: var(--color-white);
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: var(--transition);
  }

  .project-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-5px);
  }

  .project-card:focus-within {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
    border-radius: var(--border-radius);
  }

  .project-image-wrapper {
    overflow: hidden;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
  }

  .project-media {
    position: relative;
    background: linear-gradient(135deg, rgba(38, 70, 83, 0.95), rgba(42, 157, 143, 0.7));
  }

  .project-image {
    width: 100%;
    height: auto;
    display: block;
    transition: var(--transition);
  }

  .project-card:hover .project-image {
    transform: scale(1.02);
  }

  .project-content {
    padding: var(--space-lg);
  }

  .project-meta,
  .project-card h3,
  .project-card p {
    margin-left: 0;
    margin-right: 0;
  }

  .project-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .project-summary {
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .project-card h3 {
    margin-bottom: var(--space-md);
    color: var(--color-dark);
  }

  .project-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .project-highlight {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background-color: rgba(42, 157, 143, 0.08);
    color: var(--color-primary);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .project-section {
    margin-bottom: var(--space-md);
  }

  .project-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .project-proof-card {
    padding: var(--space-sm);
    border-radius: var(--border-radius-sm);
    background-color: var(--color-light);
    border: 1px solid rgba(42, 157, 143, 0.12);
  }

  .project-proof-card__value {
    margin-bottom: 0.2rem;
    font-size: 0.98rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--color-dark);
  }

  .project-proof-card__label {
    margin-bottom: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--color-text);
  }

  .project-section h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-description {
    color: var(--color-text);
    margin-bottom: 0;
    line-height: 1.7;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: var(--space-md) 0;
  }

  .tech-tag {
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-light);
    color: var(--color-primary);
    border-radius: 999px;
    font-weight: 500;
  }

  .project-result {
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: 0;
  }

  .project-reference {
    margin-bottom: 0;
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }

  .project-reference a {
    font-weight: 500;
  }

  .projects-footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-proof-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
