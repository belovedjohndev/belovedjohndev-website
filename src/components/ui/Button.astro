---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'dark';
  class?: string;
  target?: string;
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  href,
  variant = 'primary',
  class: className = '',
  target,
  rel,
  type = 'button',
} = Astro.props;

const baseClass = `btn btn-${variant}`;
const finalClass = `${baseClass} ${className}`.trim();
---

{href ? (
  <a href={href} class={finalClass} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button class={finalClass} type={type}>
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3.2rem;
    padding: 0.95rem 1.45rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.005em;
    line-height: 1.2;
    text-align: center;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: 0 12px 28px rgba(16, 32, 51, 0.08);
  }

  .btn:hover {
    transform: translateY(-1px);
    text-decoration: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-accent), #f0c388);
    color: var(--color-dark);
    border-color: rgba(193, 130, 52, 0.2);
  }

  .btn-primary:hover {
    color: var(--color-dark);
    box-shadow: 0 18px 34px rgba(216, 161, 93, 0.26);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-white);
  }

  .btn-secondary:hover {
    color: var(--color-white);
    background: rgba(255, 255, 255, 0.14);
    box-shadow: 0 16px 30px rgba(255, 255, 255, 0.08);
  }

  .btn-dark {
    background: linear-gradient(135deg, var(--color-dark), var(--color-dark-soft));
    color: var(--color-white);
    border-color: rgba(16, 32, 51, 0.12);
  }

  .btn-dark:hover {
    color: var(--color-white);
    box-shadow: 0 18px 32px rgba(16, 32, 51, 0.18);
  }
</style>
