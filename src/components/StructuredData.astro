---
interface Props {
  type?: 'Person' | 'ProfessionalService';
}

const { type = 'ProfessionalService' } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://belovedjohndev.pages.dev';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': type,
  name: 'Beloved John Dev',
  url: siteUrl,
  logo: `${siteUrl}/assets/images/logo.svg`,
  description:
    'Independent business systems developer building custom business systems, client portals, and automation tools for international clients.',
  areaServed: 'Worldwide',
  serviceType: [
    'Custom business systems',
    'Client portals and estimator tools',
    'Automation and integrations',
  ],
  sameAs: [
    'https://wa.me/855963885424',
    'https://t.me/belovedjohndev',
    'https://github.com/belovedjohndev',
  ],
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
