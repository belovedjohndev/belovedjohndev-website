---
interface Props {
  type?: 'Person' | 'ProfessionalService';
}

const { type = 'ProfessionalService' } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://belovedjohndev.com';
const logoAsset = `${siteUrl}/assets/images/logo.png?v=20260328b`;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': type,
  name: 'Beloved John Dev',
  url: siteUrl,
  email: 'support@belovedjohndev.com',
  logo: logoAsset,
  description:
    'Independent business systems developer building custom business systems, client portals, estimator tools, and automation workflows for service companies and operations-heavy teams.',
  areaServed: 'Worldwide',
  priceRange: '$1,500+',
  serviceType: [
    'Custom business systems',
    'Client portals and estimator tools',
    'Automation and integrations',
  ],
  knowsAbout: [
    'Business systems',
    'Workflow automation',
    'Client portals',
    'Estimator tools',
    'Operations software',
  ],
  contactPoint: [
    {
      '@type': 'ContactPoint',
      email: 'support@belovedjohndev.com',
      contactType: 'sales',
      areaServed: 'Worldwide',
      availableLanguage: ['en'],
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Business systems services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Custom Business Systems',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Client Portals and Estimator Tools',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Automation and Integrations',
        },
      },
    ],
  },
  sameAs: [
    'https://wa.me/855963885424',
    'https://t.me/belovedjohndev',
    'https://github.com/belovedjohndev',
  ],
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
