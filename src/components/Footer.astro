---
import { contactLinks, ctaLabels } from '../data/siteContent';

const logoAsset = '/assets/images/logo.png?v=20260328b';
---

<footer class="footer">
  <div class="container footer-layout">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Beloved John Dev home">
        <img src={logoAsset} alt="Beloved John Dev logo" width="52" height="52" loading="lazy" />
        <span>
          <strong>Beloved John Dev</strong>
          <span>Independent business systems developer</span>
        </span>
      </a>

      <p>
        Custom business systems, client portals, estimator tools, and automation for service companies
        and operations-heavy teams that need software built around real workflows.
      </p>

      <div class="footer-signals" role="list" aria-label="Working style">
        <span role="listitem">Direct builder access</span>
        <span role="listitem">Architecture-first delivery</span>
        <span role="listitem">Scoped first phases</span>
      </div>
    </div>

    <div class="footer-column">
      <p class="footer-heading">Site map</p>
      <a href="/services">Services</a>
      <a href="/case-studies">Case Studies</a>
      <a href="/process">Process</a>
      <a href="/about">About</a>
      <a href="/insights">Insights</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-column">
      <p class="footer-heading">Start here</p>
      <a href="/contact">{ctaLabels.primary}</a>
      <a href="/case-studies">{ctaLabels.secondary}</a>
      <a href={contactLinks.mailto}>{contactLinks.email}</a>
      <a href={contactLinks.whatsapp} target="_blank" rel="noopener">WhatsApp</a>
      <a href={contactLinks.telegram} target="_blank" rel="noopener">Telegram</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} Beloved John Dev. Built for high-trust service-business sales.</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 0;
    padding: 4rem 0 1.5rem;
    color: var(--color-white);
    background:
      radial-gradient(circle at top right, rgba(216, 161, 93, 0.18), transparent 20%),
      linear-gradient(180deg, #0f1d2d 0%, #0b1622 100%);
  }

  .footer-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) auto auto;
    gap: 2.5rem;
    align-items: start;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1rem;
    color: var(--color-white);
  }

  .footer-logo img {
    width: auto;
    height: 48px;
  }

  .footer-logo span {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1;
  }

  .footer-logo strong {
    font-size: 1rem;
    letter-spacing: -0.03em;
  }

  .footer-logo span span {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .footer-brand p,
  .footer-bottom p {
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.8;
  }

  .footer-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.1rem;
  }

  .footer-signals span {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    font-size: 0.84rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    min-width: 180px;
  }

  .footer-heading {
    font-size: 0.78rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-column a {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .footer-bottom {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom p {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .footer-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
