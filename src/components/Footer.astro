---
import { contactLinks, ctaLabels, primaryCtaHref } from '../data/siteContent';

const logoAssetPng = '/assets/images/logo-ui.png';
const logoAssetWebp = '/assets/images/logo-ui.webp';
---

<footer class="footer">
  <div class="container footer-layout">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Beloved John Dev home">
        <picture>
          <source srcset={logoAssetWebp} type="image/webp" />
          <img
            src={logoAssetPng}
            alt="Beloved John Dev logo"
            width="52"
            height="52"
            loading="lazy"
            decoding="async"
          />
        </picture>
        <span>
          <strong>Beloved John Dev</strong>
          <span>Independent business systems developer</span>
        </span>
      </a>

      <p>
        Custom business systems, client portals, estimator tools, and automation for service companies and
        operations-heavy teams that need software built around real workflows.
      </p>

      <p class="footer-trust" aria-label="Working style">
        Custom-coded systems · Direct builder access · Architecture-first delivery · Scoped first phases
      </p>
    </div>

    <div class="footer-column">
      <p class="footer-heading">Site map</p>
      <a href="/case-studies">Work</a>
      <a href="/services">Services</a>
      <a href="/industries">Industries</a>
      <a href="/process">Process</a>
      <a href="/about">About</a>
      <a href="/insights">Insights</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-column">
      <p class="footer-heading">Start here</p>
      <a href={primaryCtaHref}>{ctaLabels.primary}</a>
      <a href="/case-studies">{ctaLabels.secondary}</a>
      <a href={contactLinks.mailto} aria-label="Email Beloved John Dev">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {contactLinks.email}
      </a>
      <a href={contactLinks.whatsapp} target="_blank" rel="noopener" aria-label="Message on WhatsApp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
        WhatsApp
      </a>
      <a href={contactLinks.telegram} target="_blank" rel="noopener" aria-label="Message on Telegram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/></svg>
        Telegram
      </a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} Beloved John Dev. Built with Astro and deployed on Cloudflare.</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 0;
    padding: 4rem 0 1.5rem;
    color: var(--color-white);
    background:
      linear-gradient(180deg, #0f1d2d 0%, #0b1622 100%);
  }

  .footer-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) auto auto;
    gap: 2.5rem;
    align-items: start;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1rem;
    color: var(--color-white);
  }

  .footer-logo img {
    width: auto;
    height: 48px;
  }

  .footer-logo span {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1;
  }

  .footer-logo strong {
    font-size: 1rem;
    letter-spacing: 0;
  }

  .footer-logo span span {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .footer-brand p,
  .footer-bottom p {
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.8;
  }

  .footer-trust {
    margin-top: 1.1rem;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.7;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    min-width: 180px;
  }

  .footer-heading {
    font-size: 0.78rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-column a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .footer-bottom {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom p {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .footer-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
