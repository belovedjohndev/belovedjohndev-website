---
import { contactLinks, ctaLabels } from '../data/siteContent';
---

<footer class="footer">
  <div class="container footer-layout">
    <div class="footer-brand">
      <div class="footer-logo">
        <img src="/assets/images/logo.svg" alt="Beloved John Dev logo" width="50" height="50" loading="lazy" />
        <div class="footer-logo__copy">
          <strong>Beloved John Dev</strong>
          <span>Business Systems Studio</span>
        </div>
      </div>

      <p>
        Custom business systems that replace spreadsheets, manual workflows, and disconnected tools
        for service businesses, agencies, and growing teams.
      </p>

      <div class="footer-signals" role="list" aria-label="Business signals">
        <span role="listitem">Direct access to the builder</span>
        <span role="listitem">Reply within 24 hours</span>
        <span role="listitem">Built for operationally serious clients</span>
      </div>
    </div>

    <div class="footer-column">
      <p class="footer-heading">Explore</p>
      <a href="/services">Services</a>
      <a href="/case-studies">Case Studies</a>
      <a href="/insights">Insights</a>
      <a href="/process">Process</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-column">
      <p class="footer-heading">Start a conversation</p>
      <a href="/contact">{ctaLabels.primary}</a>
      <a href={contactLinks.mailto}>{contactLinks.email}</a>
      <a href={contactLinks.whatsapp} target="_blank" rel="noopener">WhatsApp</a>
      <a href={contactLinks.telegram} target="_blank" rel="noopener">Telegram</a>
      <a href={contactLinks.demo} target="_blank" rel="noopener">Live demo</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} Beloved John Dev. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(circle at top center, rgba(22, 138, 122, 0.22), transparent 30%),
      linear-gradient(180deg, var(--color-dark) 0%, #0a1623 100%);
    color: var(--color-white);
    padding: 4.5rem 0 var(--space-md);
  }

  .footer-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) auto auto;
    gap: var(--space-xl);
    align-items: start;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: var(--space-sm);
  }

  .footer-logo img {
    height: 48px;
    width: auto;
  }

  .footer-logo__copy {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .footer-logo__copy strong {
    font-size: 1.05rem;
    letter-spacing: -0.03em;
  }

  .footer-logo__copy span {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.68);
  }

  .footer-brand p,
  .footer-bottom p {
    color: rgba(255, 255, 255, 0.84);
    line-height: 1.8;
  }

  .footer-signals {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .footer-signals span {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background-color: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-heading {
    margin-bottom: 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
  }

  .footer-column a {
    color: rgba(255, 255, 255, 0.88);
    font-weight: 600;
  }

  .footer-column a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom p {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .footer-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
