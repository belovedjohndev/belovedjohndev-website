---
import { contactLinks } from '../data/siteContent';
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-logo">
      <img src="/assets/images/logo.svg" alt="Beloved John Dev logo" width="50" height="50" loading="lazy" />
      <div class="footer-logo__copy">
        <strong>Beloved John</strong>
        <span>Business Systems Consultant</span>
      </div>
    </div>
    <p>
      Independent business systems developer building custom business systems, client portals,
      and automation for companies that have outgrown spreadsheets and manual workflows.
    </p>

    <p class="footer-contact">
      <a href={contactLinks.mailto}>{contactLinks.email}</a>
      <span>·</span>
      <a href={contactLinks.demo} target="_blank" rel="noopener">Live demo</a>
    </p>

    <div class="footer-links">
      <a href="/services">Services</a>
      <a href="/case-studies">Case Studies</a>
      <a href="/insights">Insights</a>
      <a href="/process">Process</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="copyright">
      &copy; {new Date().getFullYear()} Beloved John Dev. All rights reserved.
    </div>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(circle at top center, rgba(22, 138, 122, 0.22), transparent 30%),
      linear-gradient(180deg, var(--color-dark) 0%, #0a1623 100%);
    color: var(--color-white);
    padding: 4.5rem 0 var(--space-md);
  }

  .footer-content {
    text-align: center;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    margin-bottom: var(--space-sm);
  }

  .footer-logo img {
    height: 48px;
    width: auto;
  }

  .footer-logo__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .footer-logo__copy strong {
    font-size: 1.05rem;
    letter-spacing: -0.03em;
  }

  .footer-logo__copy span {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.68);
  }

  .footer-content > p {
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    color: rgba(255, 255, 255, 0.84);
    line-height: 1.8;
  }

  .footer-contact {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    align-items: center;
    margin-top: var(--space-md);
    color: rgba(255, 255, 255, 0.74);
  }

  .footer-contact a {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
  }

  .footer-links {
    margin-top: var(--space-lg);
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    transition: var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .footer-links a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .copyright {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.875rem;
    opacity: 0.8;
  }

  @media (max-width: 560px) {
    .footer-logo {
      flex-direction: column;
    }

    .footer-logo__copy {
      align-items: center;
    }

    .footer-contact {
      flex-direction: column;
      gap: 0.4rem;
    }
  }
</style>
