---
import { primaryCtaHref } from '../data/siteContent';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/case-studies', label: 'Work' },
  { href: '/services', label: 'Services' },
  { href: '/industries', label: 'Industries' },
  { href: '/process', label: 'Process' },
  { href: '/about', label: 'About' },
  { href: '/insights', label: 'Insights' },
  { href: '/contact', label: 'Contact' },
];
const logoAssetPng = '/assets/images/logo-ui.png';
const logoAssetWebp = '/assets/images/logo-ui.webp';

const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(`${href}/`));
---

<nav class="navbar" aria-label="Main navigation">
  <div class="container nav-shell">
    <a href="/" class="logo" aria-label="Beloved John Dev home">
      <picture>
        <source srcset={logoAssetWebp} type="image/webp" />
        <img
          class="logo-mark"
          src={logoAssetPng}
          alt="Beloved John Dev logo"
          width="72"
          height="72"
          decoding="async"
          fetchpriority="high"
          loading="eager"
        />
      </picture>
      <span class="logo-copy">
        <strong>Beloved John Dev</strong>
        <span>Custom business systems</span>
      </span>
    </a>

    <button
      class="mobile-menu-btn"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="primary-navigation"
      id="mobile-menu-btn"
    >
      <span class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <ul class="nav-links" id="primary-navigation">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class:list={{ active: isActive(item.href) }}>{item.label}</a>
        </li>
      ))}
      <li class="nav-cta-item">
        <a href={primaryCtaHref} class="nav-cta">Start a Project</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 1000;
    padding: 0.65rem 0;
    background: rgba(247, 245, 240, 0.9);
    border-bottom: 1px solid rgba(16, 32, 51, 0.08);
    backdrop-filter: blur(18px);
  }

  .nav-shell {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-dark);
    flex-shrink: 0;
    min-width: 0;
  }

  .logo-mark {
    width: clamp(2.7rem, 3.8vw, 3rem);
    height: clamp(2.7rem, 3.8vw, 3rem);
    flex-shrink: 0;
    object-fit: contain;
  }

  .logo-copy {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    line-height: 1;
    min-width: 0;
  }

  .logo-copy strong {
    font-size: 1rem;
    letter-spacing: 0;
  }

  .logo-copy span {
    color: var(--color-text-muted);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex: 1 1 auto;
    gap: 0.55rem;
    list-style: none;
    min-width: 0;
  }

  .nav-links a {
    color: var(--color-ink);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .nav-links a.active {
    color: var(--color-primary);
  }

  .nav-cta-item {
    margin-left: 0.2rem;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.4rem;
    padding: 0.5rem 0.85rem;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--color-dark), var(--color-dark-soft));
    color: var(--color-white) !important;
    box-shadow: var(--shadow-sm);
    text-align: center;
    white-space: nowrap;
  }

  .nav-cta:hover {
    color: var(--color-white);
  }

  .mobile-menu-btn {
    display: none;
    border: none;
    background: transparent;
    color: var(--color-dark);
    cursor: pointer;
    line-height: 0;
    padding: 0.3rem;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 1150px) {
    .nav-links {
      gap: 0.45rem;
    }

    .nav-links a {
      font-size: 0.84rem;
    }

    .nav-cta {
      padding-inline: 0.75rem;
    }
  }

  @media (max-width: 1080px) {
    .nav-cta-item {
      display: none;
    }
  }

  @media (max-width: 980px) {
    .logo-mark {
      width: 2.6rem;
      height: 2.6rem;
    }

    .logo-copy span {
      display: none;
    }

    .nav-links {
      gap: 0.7rem;
    }
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 0.6rem 0;
    }

    .mobile-menu-btn {
      display: block;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 0 1.25rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.65rem;
      background: rgba(255, 255, 255, 0.97);
      border-bottom: 1px solid rgba(16, 32, 51, 0.08);
      box-shadow: var(--shadow-md);
      z-index: 10;
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, opacity 0.25s ease, padding 0.3s ease;
    }

    .nav-links.active {
      max-height: 400px;
      opacity: 1;
      padding: 0.85rem 1.25rem 1rem;
    }

    .nav-cta-item {
      display: flex;
      width: 100%;
      margin-left: 0;
      padding-top: 0.3rem;
    }

    .nav-cta {
      width: 100%;
    }
  }

  @media (max-width: 560px) {
    .logo-mark {
      width: 2.25rem;
      height: 2.25rem;
    }

    .logo-copy {
      display: none;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const navLinks = document.getElementById('primary-navigation');

  if (menuBtn && navLinks) {
    menuBtn.addEventListener('click', () => {
      const isExpanded = navLinks.classList.toggle('active');
      menuBtn.setAttribute('aria-expanded', String(isExpanded));
    });

    navLinks.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('active');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
