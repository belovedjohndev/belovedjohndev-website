---
import { ctaLabels } from '../data/siteContent';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/services', label: 'Services' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/process', label: 'Process' },
  { href: '/about', label: 'About' },
  { href: '/insights', label: 'Insights' },
  { href: '/contact', label: 'Contact' },
];

const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(`${href}/`));
---

<nav class="navbar" aria-label="Main navigation">
  <div class="container nav-shell">
    <a href="/" class="logo" aria-label="Beloved John Dev home">
      <img src="/assets/images/logo.svg" alt="Beloved John Dev logo" width="50" height="50" loading="eager" />
      <span class="logo-copy">
        <strong>Beloved John Dev</strong>
        <span>Business systems for service companies</span>
      </span>
    </a>

    <button
      class="mobile-menu-btn"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="primary-navigation"
      id="mobile-menu-btn"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18" />
      </svg>
    </button>

    <ul class="nav-links" id="primary-navigation">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class:list={{ active: isActive(item.href) }}>{item.label}</a>
        </li>
      ))}
      <li class="nav-cta-item">
        <a href="/contact" class="nav-cta">{ctaLabels.primary}</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 1000;
    padding: 0.9rem 0;
    background: rgba(247, 245, 240, 0.9);
    border-bottom: 1px solid rgba(16, 32, 51, 0.08);
    backdrop-filter: blur(18px);
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--color-dark);
    flex-shrink: 0;
  }

  .logo img {
    width: auto;
    height: 46px;
  }

  .logo-copy {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1;
  }

  .logo-copy strong {
    font-size: 0.98rem;
    letter-spacing: -0.03em;
  }

  .logo-copy span {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--color-ink);
    font-size: 0.94rem;
    font-weight: 700;
  }

  .nav-links a.active {
    color: var(--color-primary);
  }

  .nav-cta-item {
    margin-left: 0.4rem;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-dark), var(--color-dark-soft));
    color: var(--color-white) !important;
    box-shadow: var(--shadow-sm);
  }

  .nav-cta:hover {
    color: var(--color-white);
  }

  .mobile-menu-btn {
    display: none;
    border: none;
    background: transparent;
    color: var(--color-dark);
    cursor: pointer;
    line-height: 0;
  }

  @media (max-width: 980px) {
    .logo-copy span {
      display: none;
    }

    .nav-links {
      gap: 1rem;
    }

    .nav-cta-item {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .mobile-menu-btn {
      display: block;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 1rem 1.5rem 1.25rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.9rem;
      background: rgba(255, 255, 255, 0.97);
      border-bottom: 1px solid rgba(16, 32, 51, 0.08);
      box-shadow: var(--shadow-md);
    }

    .nav-links.active {
      display: flex;
    }

    .nav-cta-item {
      display: flex;
      width: 100%;
      margin-left: 0;
      padding-top: 0.4rem;
    }

    .nav-cta {
      width: 100%;
    }
  }

  @media (max-width: 560px) {
    .logo-copy {
      display: none;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const navLinks = document.getElementById('primary-navigation');

  if (menuBtn && navLinks) {
    menuBtn.addEventListener('click', () => {
      const isExpanded = navLinks.classList.toggle('active');
      menuBtn.setAttribute('aria-expanded', String(isExpanded));
    });

    navLinks.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('active');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
