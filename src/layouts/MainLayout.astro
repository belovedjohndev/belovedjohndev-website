---
import '../styles/global.css';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  robots?: string;
  structuredDataType?: 'Person' | 'ProfessionalService' | false;
}

const {
  title,
  description,
  canonical = Astro.url.pathname,
  ogImage = '/assets/images/hero-bg.png',
  ogImageAlt = title,
  robots = 'index, follow',
  structuredDataType = 'ProfessionalService',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://belovedjohndev.com';
const fullUrl = `${siteUrl}${canonical === '/' ? '' : canonical}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Beloved John Dev" />
    <meta name="theme-color" content="#102033" />
    <link rel="canonical" href={fullUrl} />
    
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Beloved John Dev" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />
    <meta property="twitter:image:alt" content={ogImageAlt} />
    
    <meta name="robots" content={robots} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" href="/favicon.ico" />
    
    <link rel="preload" as="image" href="/assets/images/hero-bg.webp" type="image/webp" />
    
    {structuredDataType && <StructuredData type={structuredDataType} />}
    
    <link rel="dns-prefetch" href="https://wa.me" />
    <link rel="dns-prefetch" href="https://t.me" />
    
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    
    <slot name="navbar" />
    
    <main id="main">
      <slot />
    </main>
    
    <slot name="footer" />
    
    <slot name="scripts" />
  </body>
</html>
